{
  "$id": "https://rootlight.local/schema/mcp/symbol.explain/input/1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SymbolExplainInput",
  "description": "Strict input for `symbol.explain`.",
  "type": "object",
  "properties": {
    "budget": {
      "description": "Optional lower response limits.",
      "anyOf": [
        {
          "$ref": "#/$defs/ResponseBudget"
        }
      ]
    },
    "generation": {
      "description": "Immutable generation selector.",
      "anyOf": [
        {
          "$ref": "#/$defs/GenerationSelector"
        }
      ]
    },
    "include_provenance": {
      "description": "Provenance detail.",
      "anyOf": [
        {
          "$ref": "#/$defs/ProvenanceLevel"
        }
      ]
    },
    "relation_sample_limit": {
      "description": "Per-relation evidence sample ceiling.",
      "type": "integer",
      "format": "uint8",
      "maximum": 25,
      "minimum": 0
    },
    "repository": {
      "description": "Owning repository.",
      "$ref": "#/$defs/RepositorySelector"
    },
    "response_profile": {
      "description": "Requested representation.",
      "anyOf": [
        {
          "$ref": "#/$defs/ResponseProfile"
        }
      ]
    },
    "sections": {
      "description": "Requested sections.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/ExplainSection"
      },
      "maxItems": 10,
      "uniqueItems": true
    },
    "source_preview_lines": {
      "description": "Source preview lines per symbol.",
      "type": "integer",
      "format": "uint8",
      "maximum": 40,
      "minimum": 0
    },
    "symbol_ids": {
      "description": "Stable unambiguous symbols.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/SymbolId"
      },
      "maxItems": 16,
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "additionalProperties": false,
  "required": [
    "repository",
    "symbol_ids"
  ],
  "$defs": {
    "ActiveGeneration": {
      "description": "Active-generation keyword.",
      "oneOf": [
        {
          "description": "Select the active generation.",
          "type": "string",
          "const": "active"
        }
      ]
    },
    "ExplainSection": {
      "description": "Sections accepted by `symbol.explain`.",
      "oneOf": [
        {
          "description": "Compact signature.",
          "type": "string",
          "const": "signature"
        },
        {
          "description": "Documentation evidence.",
          "type": "string",
          "const": "docs"
        },
        {
          "description": "Containment evidence.",
          "type": "string",
          "const": "containment"
        },
        {
          "description": "Type evidence.",
          "type": "string",
          "const": "types"
        },
        {
          "description": "Outbound and inbound call summary.",
          "type": "string",
          "const": "calls_summary"
        },
        {
          "description": "Reference summary.",
          "type": "string",
          "const": "references_summary"
        },
        {
          "description": "History evidence.",
          "type": "string",
          "const": "history"
        },
        {
          "description": "Ownership evidence.",
          "type": "string",
          "const": "ownership"
        },
        {
          "description": "Diagnostics.",
          "type": "string",
          "const": "diagnostics"
        },
        {
          "description": "Small source preview.",
          "type": "string",
          "const": "source_preview"
        }
      ]
    },
    "GenerationId": {
      "type": "string",
      "pattern": "^gen1_[a-z2-7]{39}$"
    },
    "GenerationSelector": {
      "description": "Generation selector shared by first-slice read tools.",
      "anyOf": [
        {
          "description": "Resolve the currently active immutable generation.",
          "$ref": "#/$defs/ActiveGeneration"
        },
        {
          "description": "Pin an explicit immutable generation.",
          "$ref": "#/$defs/GenerationId"
        }
      ]
    },
    "ProvenanceLevel": {
      "description": "Provenance detail requested by a read tool.",
      "oneOf": [
        {
          "description": "Omit provenance detail beyond mandatory source identity.",
          "type": "string",
          "const": "none"
        },
        {
          "description": "Return compact provider and confidence evidence.",
          "type": "string",
          "const": "compact"
        },
        {
          "description": "Return maximum bounded provenance evidence.",
          "type": "string",
          "const": "full"
        }
      ]
    },
    "RepositoryAliasSelector": {
      "description": "Registered repository-alias selector.",
      "type": "object",
      "properties": {
        "alias": {
          "description": "Registered alias, resolved to exactly one repository.",
          "type": "string",
          "maxLength": 256,
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "alias"
      ]
    },
    "RepositoryId": {
      "type": "string",
      "pattern": "^repo1_[a-z2-7]{32}$"
    },
    "RepositoryIdSelector": {
      "description": "Stable repository-ID selector.",
      "type": "object",
      "properties": {
        "repository_id": {
          "description": "Repository identity.",
          "$ref": "#/$defs/RepositoryId"
        }
      },
      "additionalProperties": false,
      "required": [
        "repository_id"
      ]
    },
    "RepositorySelector": {
      "description": "Repository selector accepted by first-slice read tools.",
      "anyOf": [
        {
          "description": "Select by stable repository identifier.",
          "$ref": "#/$defs/RepositoryIdSelector"
        },
        {
          "description": "Select by a configured local alias.",
          "$ref": "#/$defs/RepositoryAliasSelector"
        }
      ]
    },
    "ResponseBudget": {
      "description": "Optional response limits that can only reduce server hard limits.",
      "type": "object",
      "properties": {
        "evidence_level": {
          "description": "Requested evidence detail.",
          "anyOf": [
            {
              "$ref": "#/$defs/ProvenanceLevel"
            }
          ]
        },
        "max_depth": {
          "description": "Maximum plan depth.",
          "type": "integer",
          "format": "uint8",
          "maximum": 16,
          "minimum": 1
        },
        "max_paths": {
          "description": "Maximum independently returned paths.",
          "type": "integer",
          "format": "uint16",
          "maximum": 1000,
          "minimum": 1
        },
        "max_results": {
          "description": "Maximum returned result objects.",
          "type": "integer",
          "format": "uint16",
          "maximum": 1000,
          "minimum": 1
        },
        "max_source_bytes": {
          "description": "Maximum source bytes before JSON escaping.",
          "type": "integer",
          "format": "uint32",
          "maximum": 524288,
          "minimum": 1
        },
        "max_tokens": {
          "description": "Maximum estimated output tokens.",
          "type": "integer",
          "format": "uint16",
          "maximum": 3200,
          "minimum": 100
        },
        "max_traversal_facts": {
          "description": "Maximum relationship or traversal facts examined.",
          "type": "integer",
          "format": "uint32",
          "maximum": 100000,
          "minimum": 1
        },
        "timeout_ms": {
          "description": "Cooperative request deadline in milliseconds.",
          "type": "integer",
          "format": "uint32",
          "maximum": 30000,
          "minimum": 10
        }
      },
      "additionalProperties": false
    },
    "ResponseProfile": {
      "description": "Requested response representation.",
      "oneOf": [
        {
          "description": "Smallest complete correctness-bearing response.",
          "type": "string",
          "const": "compact"
        },
        {
          "description": "More explanatory response within the same hard budgets.",
          "type": "string",
          "const": "standard"
        },
        {
          "description": "Maximum bounded provenance and evidence.",
          "type": "string",
          "const": "evidence"
        }
      ]
    },
    "SymbolId": {
      "type": "string",
      "pattern": "^sym1_[a-z2-7]{39}$"
    }
  }
}
