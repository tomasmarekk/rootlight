{
  "$id": "https://rootlight.local/schema/mcp/tests.select/input/1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TestsSelectInput",
  "description": "Strict input for `tests.select`.",
  "type": "object",
  "properties": {
    "budget": {
      "description": "Response budget overrides.",
      "anyOf": [
        {
          "$ref": "#/$defs/ResponseBudget"
        }
      ]
    },
    "execution_budget": {
      "description": "Execution budget hint.",
      "anyOf": [
        {
          "$ref": "#/$defs/ExecutionBudget"
        }
      ]
    },
    "frameworks": {
      "description": "Filter to specific test frameworks.",
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 256,
        "minLength": 1
      },
      "maxItems": 32,
      "minItems": 1
    },
    "generation": {
      "description": "Generation to analyze against.",
      "anyOf": [
        {
          "$ref": "#/$defs/GenerationSelector"
        }
      ]
    },
    "include_commands": {
      "description": "Whether to include declarative command metadata.",
      "type": "boolean"
    },
    "max_tests": {
      "description": "Maximum tests to return.",
      "type": "integer",
      "format": "uint16",
      "maximum": 500,
      "minimum": 1
    },
    "profile": {
      "description": "Requested response profile.",
      "anyOf": [
        {
          "$ref": "#/$defs/ResponseProfile"
        }
      ]
    },
    "repository": {
      "description": "Repository or workspace selector.",
      "$ref": "#/$defs/RepositorySelector"
    },
    "seeds": {
      "description": "Seed selector for relevance.",
      "$ref": "#/$defs/TestSeedSelector"
    },
    "test_kinds": {
      "description": "Filter to specific test kinds.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/TestKind"
      },
      "maxItems": 6,
      "minItems": 1
    }
  },
  "additionalProperties": false,
  "required": [
    "repository",
    "seeds"
  ],
  "$defs": {
    "ActiveGeneration": {
      "description": "Active-generation keyword.",
      "oneOf": [
        {
          "description": "Select the active generation.",
          "type": "string",
          "const": "active"
        }
      ]
    },
    "ChangeSelector": {
      "description": "Selector for the change set to analyze.",
      "type": "object",
      "properties": {
        "paths": {
          "description": "Explicit file paths known to be changed.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 8192,
            "minLength": 1
          },
          "maxItems": 1000,
          "minItems": 1
        },
        "revision_range": {
          "description": "Explicit Git revision range.",
          "type": "string",
          "maxLength": 512,
          "minLength": 1
        },
        "symbol_ids": {
          "description": "Explicit symbol identifiers known to be changed.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/SymbolId"
          },
          "maxItems": 256,
          "minItems": 1
        },
        "working_tree": {
          "description": "Working-tree state to diff.",
          "anyOf": [
            {
              "$ref": "#/$defs/WorkingTreeState"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "ExecutionBudget": {
      "description": "Execution budget hint for test selection.",
      "type": "object",
      "properties": {
        "max_slow_tests": {
          "description": "Maximum number of slow tests to include.",
          "type": "integer",
          "format": "uint16",
          "maximum": 500,
          "minimum": 0
        },
        "max_total_ms": {
          "description": "Maximum estimated total execution time in milliseconds.",
          "type": "integer",
          "format": "uint32",
          "maximum": 3600000,
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "GenerationId": {
      "type": "string",
      "pattern": "^gen1_[a-z2-7]{39}$"
    },
    "GenerationSelector": {
      "description": "Generation selector shared by first-slice read tools.",
      "anyOf": [
        {
          "description": "Resolve the currently active immutable generation.",
          "$ref": "#/$defs/ActiveGeneration"
        },
        {
          "description": "Pin an explicit immutable generation.",
          "$ref": "#/$defs/GenerationId"
        }
      ]
    },
    "ProvenanceLevel": {
      "description": "Provenance detail requested by a read tool.",
      "oneOf": [
        {
          "description": "Omit provenance detail beyond mandatory source identity.",
          "type": "string",
          "const": "none"
        },
        {
          "description": "Return compact provider and confidence evidence.",
          "type": "string",
          "const": "compact"
        },
        {
          "description": "Return maximum bounded provenance evidence.",
          "type": "string",
          "const": "full"
        }
      ]
    },
    "RepositoryAliasSelector": {
      "description": "Registered repository-alias selector.",
      "type": "object",
      "properties": {
        "alias": {
          "description": "Registered alias, resolved to exactly one repository.",
          "type": "string",
          "maxLength": 256,
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "alias"
      ]
    },
    "RepositoryId": {
      "type": "string",
      "pattern": "^repo1_[a-z2-7]{32}$"
    },
    "RepositoryIdSelector": {
      "description": "Stable repository-ID selector.",
      "type": "object",
      "properties": {
        "repository_id": {
          "description": "Repository identity.",
          "$ref": "#/$defs/RepositoryId"
        }
      },
      "additionalProperties": false,
      "required": [
        "repository_id"
      ]
    },
    "RepositorySelector": {
      "description": "Repository selector accepted by first-slice read tools.",
      "anyOf": [
        {
          "description": "Select by stable repository identifier.",
          "$ref": "#/$defs/RepositoryIdSelector"
        },
        {
          "description": "Select by a configured local alias.",
          "$ref": "#/$defs/RepositoryAliasSelector"
        }
      ]
    },
    "ResponseBudget": {
      "description": "Optional response limits that can only reduce server hard limits.",
      "type": "object",
      "properties": {
        "evidence_level": {
          "description": "Requested evidence detail.",
          "anyOf": [
            {
              "$ref": "#/$defs/ProvenanceLevel"
            }
          ]
        },
        "max_depth": {
          "description": "Maximum plan depth.",
          "type": "integer",
          "format": "uint8",
          "maximum": 16,
          "minimum": 1
        },
        "max_paths": {
          "description": "Maximum independently returned paths.",
          "type": "integer",
          "format": "uint16",
          "maximum": 1000,
          "minimum": 1
        },
        "max_results": {
          "description": "Maximum returned result objects.",
          "type": "integer",
          "format": "uint16",
          "maximum": 1000,
          "minimum": 1
        },
        "max_source_bytes": {
          "description": "Maximum source bytes before JSON escaping.",
          "type": "integer",
          "format": "uint32",
          "maximum": 524288,
          "minimum": 1
        },
        "max_tokens": {
          "description": "Maximum estimated output tokens.\n\nThe schema ceiling is the largest aggregate budget any tool accepts\n(`query.batch` allows up to 16000); the server clamps each request to\nthe calling tool's own hard limit.",
          "type": "integer",
          "format": "uint16",
          "maximum": 16000,
          "minimum": 100
        },
        "max_traversal_facts": {
          "description": "Maximum relationship or traversal facts examined.",
          "type": "integer",
          "format": "uint32",
          "maximum": 100000,
          "minimum": 1
        },
        "timeout_ms": {
          "description": "Cooperative request deadline in milliseconds.",
          "type": "integer",
          "format": "uint32",
          "maximum": 30000,
          "minimum": 10
        }
      },
      "additionalProperties": false
    },
    "ResponseProfile": {
      "description": "Requested response representation.",
      "oneOf": [
        {
          "description": "Smallest complete correctness-bearing response.",
          "type": "string",
          "const": "compact"
        },
        {
          "description": "More explanatory response within the same hard budgets.",
          "type": "string",
          "const": "standard"
        },
        {
          "description": "Maximum bounded provenance and evidence.",
          "type": "string",
          "const": "evidence"
        }
      ]
    },
    "SymbolId": {
      "type": "string",
      "pattern": "^sym1_[a-z2-7]{39}$"
    },
    "TestKind": {
      "description": "Kind of test relevant to a change.",
      "oneOf": [
        {
          "description": "Unit-level test.",
          "type": "string",
          "const": "unit"
        },
        {
          "description": "Integration test spanning components.",
          "type": "string",
          "const": "integration"
        },
        {
          "description": "End-to-end test.",
          "type": "string",
          "const": "e2e"
        },
        {
          "description": "Contract or schema compatibility test.",
          "type": "string",
          "const": "contract"
        },
        {
          "description": "Static analysis or lint check.",
          "type": "string",
          "const": "static"
        },
        {
          "description": "Build or compilation verification.",
          "type": "string",
          "const": "build"
        }
      ]
    },
    "TestSeedSelector": {
      "description": "Seed selector for test relevance.",
      "type": "object",
      "properties": {
        "build_targets": {
          "description": "Build target identities to seed from.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 512,
            "minLength": 1
          },
          "maxItems": 128,
          "minItems": 1
        },
        "change": {
          "description": "A change selector to derive seeds from.",
          "anyOf": [
            {
              "$ref": "#/$defs/ChangeSelector"
            }
          ]
        },
        "paths": {
          "description": "File paths to seed from.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 8192,
            "minLength": 1
          },
          "maxItems": 256,
          "minItems": 1
        },
        "symbols": {
          "description": "Symbol identifiers to seed from.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/SymbolId"
          },
          "maxItems": 64,
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "WorkingTreeState": {
      "description": "Working-tree diff state.",
      "oneOf": [
        {
          "description": "Unstaged changes only.",
          "type": "string",
          "const": "unstaged"
        },
        {
          "description": "Staged changes only.",
          "type": "string",
          "const": "staged"
        },
        {
          "description": "All working-tree changes including staged.",
          "type": "string",
          "const": "all"
        }
      ]
    }
  }
}
