{
  "$id": "https://rootlight.local/schema/mcp/code.dead/output/1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ToolResponse",
  "description": "A checked success-or-error result accepted by one tool output schema.\n\nSuccessful variants preserve each tool's documented response shape.\nExpected domain failures use the same versioned [`ErrorResponse`] and\nchecked [`PublicError`] contract for every tool.",
  "type": "object",
  "anyOf": [
    {
      "description": "A tool-specific successful response.",
      "$ref": "#/$defs/ReadEnvelope"
    },
    {
      "description": "A versioned source-redacted domain error.",
      "$ref": "#/$defs/ErrorResponse"
    }
  ],
  "unevaluatedProperties": false,
  "$defs": {
    "AnalysisTier": {
      "description": "Requested or observed language support tier.",
      "oneOf": [
        {
          "description": "Compiler-quality or equivalent semantic evidence.",
          "type": "string",
          "const": "A"
        },
        {
          "description": "High-confidence partial semantic evidence.",
          "type": "string",
          "const": "B"
        },
        {
          "description": "Generic structural extraction.",
          "type": "string",
          "const": "C"
        },
        {
          "description": "Lexical-only support.",
          "type": "string",
          "const": "D"
        }
      ]
    },
    "BlindSpot": {
      "description": "One known blind spot in the reachability analysis.",
      "type": "object",
      "properties": {
        "affected_count": {
          "description": "Number of symbols potentially affected.",
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "category": {
          "description": "Source-free blind-spot category label.",
          "type": "string",
          "maxLength": 256,
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "category",
        "affected_count"
      ]
    },
    "CacheStatus": {
      "description": "Cache classification for usage reporting.",
      "oneOf": [
        {
          "description": "No cache entry was used.",
          "type": "string",
          "const": "miss"
        },
        {
          "description": "A verified generation-bound cache entry was used.",
          "type": "string",
          "const": "hit"
        },
        {
          "description": "The operator does not use a cache.",
          "type": "string",
          "const": "not_applicable"
        }
      ]
    },
    "CodeDeadData": {
      "description": "`code.dead` result data.",
      "type": "object",
      "properties": {
        "blind_spots": {
          "description": "Known analysis blind spots.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/BlindSpot"
          },
          "maxItems": 32
        },
        "candidates": {
          "description": "Ranked dead-code candidates.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/DeadCandidate"
          },
          "maxItems": 500
        },
        "entry_points": {
          "description": "Entry-point model summary.",
          "$ref": "#/$defs/EntryPointSummary"
        },
        "explanation": {
          "description": "Bounded source-free plan present when explain was requested.",
          "anyOf": [
            {
              "$ref": "#/$defs/PlanExplanation"
            },
            {
              "type": "null"
            }
          ]
        },
        "false_positive_controls": {
          "description": "Applied false-positive suppression rules.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/RuleSummary"
          },
          "maxItems": 32
        }
      },
      "additionalProperties": false,
      "required": [
        "candidates",
        "entry_points",
        "blind_spots",
        "false_positive_controls"
      ]
    },
    "ContentHash": {
      "type": "string",
      "pattern": "^b3_[a-z2-7]{58}$"
    },
    "ContinuationCursor": {
      "description": "A bounded opaque continuation cursor.",
      "type": "string",
      "maxLength": 4096,
      "minLength": 1
    },
    "CoverageStatus": {
      "description": "Completeness of a bounded fact or result set.",
      "oneOf": [
        {
          "description": "The declared domain was completely analyzed.",
          "type": "string",
          "const": "complete"
        },
        {
          "description": "A documented bound truncated the domain.",
          "type": "string",
          "const": "bounded"
        },
        {
          "description": "A representative sample was analyzed.",
          "type": "string",
          "const": "sampled"
        },
        {
          "description": "Completeness could not be established.",
          "type": "string",
          "const": "unknown"
        }
      ]
    },
    "CoverageSummary": {
      "description": "Coverage metadata relevant to one query.",
      "type": "object",
      "properties": {
        "languages": {
          "description": "Deterministically ordered language coverage.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/LanguageCoverage"
          },
          "maxItems": 64
        },
        "skipped_inputs": {
          "description": "Inputs skipped by policy, limits, or capability.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "status": {
          "description": "Aggregate query-domain coverage.",
          "$ref": "#/$defs/CoverageStatus"
        }
      },
      "additionalProperties": false,
      "required": [
        "status",
        "languages",
        "skipped_inputs"
      ]
    },
    "DeadCandidate": {
      "description": "One dead-code candidate with evidence and caveats.",
      "type": "object",
      "properties": {
        "classification": {
          "description": "Reachability classification.",
          "$ref": "#/$defs/DeadClassification"
        },
        "confidence": {
          "description": "Confidence from 0 through 1000.",
          "type": "integer",
          "format": "uint16",
          "maximum": 1000,
          "minimum": 0
        },
        "source_refs": {
          "description": "Source evidence for the candidate.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/SourceRef"
          },
          "maxItems": 8
        },
        "suppressions_checked": {
          "description": "Suppression rules checked for this candidate.",
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 16
        },
        "symbol_id": {
          "description": "Stable symbol identity.",
          "$ref": "#/$defs/SymbolId"
        },
        "trust": {
          "description": "Trust classification for repository-derived content.",
          "$ref": "#/$defs/TrustClassification"
        },
        "why": {
          "description": "Source-free reasons supporting the classification.",
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 16,
          "minItems": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "symbol_id",
        "classification",
        "confidence",
        "why",
        "suppressions_checked",
        "source_refs",
        "trust"
      ]
    },
    "DeadClassification": {
      "description": "Classification confidence for a dead-code candidate.",
      "oneOf": [
        {
          "description": "Proven unreachable under the entry-point model.",
          "type": "string",
          "const": "proven_dead"
        },
        {
          "description": "Probable dead code with high confidence.",
          "type": "string",
          "const": "probable_dead"
        },
        {
          "description": "Suspected dead code with moderate confidence.",
          "type": "string",
          "const": "suspected_dead"
        }
      ]
    },
    "DetailKey": {
      "description": "A validated key for a bounded public error detail.",
      "type": "string",
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^[a-z0-9_]+$"
    },
    "EntryPointPolicy": {
      "description": "Entry-point model policy for dead code analysis.",
      "oneOf": [
        {
          "description": "Standard mixed entry-point model.",
          "type": "string",
          "const": "standard"
        },
        {
          "description": "Library export surface as entry points.",
          "type": "string",
          "const": "library"
        },
        {
          "description": "Application main and registered handlers.",
          "type": "string",
          "const": "application"
        }
      ]
    },
    "EntryPointSummary": {
      "description": "Summary of the entry-point model used for reachability.",
      "type": "object",
      "properties": {
        "complete": {
          "description": "Whether the model is complete for the scope.",
          "type": "boolean"
        },
        "entry_point_count": {
          "description": "Number of resolved entry points.",
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "policy": {
          "description": "Policy used for entry-point resolution.",
          "$ref": "#/$defs/EntryPointPolicy"
        }
      },
      "additionalProperties": false,
      "required": [
        "policy",
        "entry_point_count",
        "complete"
      ]
    },
    "ErrorCode": {
      "description": "Stable public error families shared by all Rootlight boundaries.",
      "oneOf": [
        {
          "description": "The caller supplied an invalid value.",
          "type": "string",
          "const": "INVALID_ARGUMENT"
        },
        {
          "description": "The requested entity does not exist.",
          "type": "string",
          "const": "NOT_FOUND"
        },
        {
          "description": "The request conflicts with current state.",
          "type": "string",
          "const": "CONFLICT"
        },
        {
          "description": "The selected generation is no longer valid for this operation.",
          "type": "string",
          "const": "STALE_GENERATION"
        },
        {
          "description": "The requested capability is unavailable.",
          "type": "string",
          "const": "UNSUPPORTED_CAPABILITY"
        },
        {
          "description": "The result is incomplete for the requested coverage.",
          "type": "string",
          "const": "INCOMPLETE_COVERAGE"
        },
        {
          "description": "The operation exceeded an explicit work budget.",
          "type": "string",
          "const": "BUDGET_EXCEEDED"
        },
        {
          "description": "A bounded resource is exhausted.",
          "type": "string",
          "const": "RESOURCE_EXHAUSTED"
        },
        {
          "description": "The operation was cancelled before completion.",
          "type": "string",
          "const": "CANCELLED"
        },
        {
          "description": "An isolated adapter failed.",
          "type": "string",
          "const": "ADAPTER_FAILED"
        },
        {
          "description": "An index failed integrity checks.",
          "type": "string",
          "const": "INDEX_CORRUPT"
        },
        {
          "description": "Stored data requires a supported migration.",
          "type": "string",
          "const": "MIGRATION_REQUIRED"
        },
        {
          "description": "Policy denied the requested operation.",
          "type": "string",
          "const": "PERMISSION_DENIED"
        },
        {
          "description": "A protocol or contract version is incompatible.",
          "type": "string",
          "const": "PROTOCOL_MISMATCH"
        },
        {
          "description": "A conflicting operation temporarily owns the resource.",
          "type": "string",
          "const": "BUSY"
        },
        {
          "description": "An internal failure cannot be safely disclosed.",
          "type": "string",
          "const": "INTERNAL"
        },
        {
          "description": "A pagination cursor is invalid, expired, forged, or context-mismatched.",
          "type": "string",
          "const": "INVALID_CURSOR"
        },
        {
          "description": "A supplied value has the wrong type for its target field.",
          "type": "string",
          "const": "TYPE_MISMATCH"
        },
        {
          "description": "The request exceeded a cost limit before execution.",
          "type": "string",
          "const": "COST_LIMIT"
        },
        {
          "description": "The query uses an operator outside the documented allowlist.",
          "type": "string",
          "const": "OPERATOR_FORBIDDEN"
        },
        {
          "description": "A batch binding reference is malformed or unresolved.",
          "type": "string",
          "const": "BINDING_INVALID"
        },
        {
          "description": "A batch binding produced a value of the wrong type for its target.",
          "type": "string",
          "const": "BINDING_TYPE_MISMATCH"
        }
      ]
    },
    "ErrorResponse": {
      "description": "Strict common error response for MCP contract failures.",
      "type": "object",
      "properties": {
        "error": {
          "description": "Stable public error envelope.",
          "$ref": "#/$defs/PublicError"
        },
        "schema_version": {
          "description": "Tool error schema version.",
          "$ref": "#/$defs/SchemaVersion"
        }
      },
      "additionalProperties": false,
      "required": [
        "schema_version",
        "error"
      ]
    },
    "FileId": {
      "type": "string",
      "pattern": "^file1_[a-z2-7]{39}$"
    },
    "Freshness": {
      "description": "Freshness of one immutable generation.",
      "oneOf": [
        {
          "description": "Matches the currently observed repository snapshot.",
          "type": "string",
          "const": "current"
        },
        {
          "description": "Queryable but a newer generation exists.",
          "type": "string",
          "const": "superseded"
        },
        {
          "description": "Queryable with a known stale source snapshot.",
          "type": "string",
          "const": "stale"
        }
      ]
    },
    "GenerationId": {
      "type": "string",
      "pattern": "^gen1_[a-z2-7]{39}$"
    },
    "GenerationSummary": {
      "description": "Generation metadata carried by each read response.",
      "type": "object",
      "properties": {
        "generation_id": {
          "description": "Pinned generation.",
          "$ref": "#/$defs/GenerationId"
        },
        "parent_generation": {
          "description": "Parent generation, if any.",
          "$ref": "#/$defs/RequiredNullable"
        },
        "semantic_freshness": {
          "description": "Semantic freshness.",
          "$ref": "#/$defs/Freshness"
        },
        "structural_freshness": {
          "description": "Structural freshness.",
          "$ref": "#/$defs/Freshness"
        }
      },
      "additionalProperties": false,
      "required": [
        "generation_id",
        "parent_generation",
        "structural_freshness",
        "semantic_freshness"
      ]
    },
    "LanguageCoverage": {
      "description": "Per-language coverage summary.",
      "type": "object",
      "properties": {
        "language": {
          "description": "Language identity.",
          "type": "string",
          "maxLength": 64,
          "minLength": 1
        },
        "status": {
          "description": "Coverage state for this language.",
          "$ref": "#/$defs/CoverageStatus"
        },
        "tier": {
          "description": "Observed support tier.",
          "$ref": "#/$defs/AnalysisTier"
        }
      },
      "additionalProperties": false,
      "required": [
        "language",
        "tier",
        "status"
      ]
    },
    "LineRange": {
      "description": "A validated one-based inclusive source line range.",
      "type": "object",
      "properties": {
        "end_line": {
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 1
        },
        "start_line": {
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "start_line",
        "end_line"
      ]
    },
    "NextAction": {
      "description": "Stable remediation hints generated from a closed set of templates.",
      "oneOf": [
        {
          "description": "Correct one named input field.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "correct_field"
            },
            "field": {
              "description": "Stable name of the invalid field.",
              "$ref": "#/$defs/DetailKey"
            }
          },
          "additionalProperties": false,
          "required": [
            "action",
            "field"
          ]
        },
        {
          "description": "Retry after the bounded delay in the envelope.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "retry"
            }
          },
          "additionalProperties": false,
          "required": [
            "action"
          ]
        },
        {
          "description": "Select a compatible contract version.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "select_supported_version"
            }
          },
          "additionalProperties": false,
          "required": [
            "action"
          ]
        },
        {
          "description": "Inspect the associated operation status.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "inspect_operation"
            }
          },
          "additionalProperties": false,
          "required": [
            "action"
          ]
        },
        {
          "description": "Rebuild the affected repository generation.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "rebuild_repository"
            }
          },
          "additionalProperties": false,
          "required": [
            "action"
          ]
        },
        {
          "description": "Collect a protected source-free support bundle.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "collect_support_bundle"
            }
          },
          "additionalProperties": false,
          "required": [
            "action"
          ]
        },
        {
          "description": "Restart the enumeration or query from the beginning after an invalid\ncontinuation cursor.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "restart_enumeration"
            }
          },
          "additionalProperties": false,
          "required": [
            "action"
          ]
        }
      ]
    },
    "OperationId": {
      "type": "string",
      "pattern": "^op1_[a-z2-7]{32}$"
    },
    "PlanExplanation": {
      "description": "Explainable cost and plan for an advanced query execution.",
      "type": "object",
      "properties": {
        "applied_limits": {
          "description": "Applied limit descriptions.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 256,
            "minLength": 1
          },
          "maxItems": 16
        },
        "estimated_cost": {
          "description": "Estimated total cost units for the query plan.",
          "type": "integer",
          "format": "uint64",
          "maximum": 10000000,
          "minimum": 0
        },
        "operators": {
          "description": "Ordered operator names in the physical plan.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 128,
            "minLength": 1
          },
          "maxItems": 64
        }
      },
      "additionalProperties": false,
      "required": [
        "estimated_cost",
        "operators",
        "applied_limits"
      ]
    },
    "PublicError": {
      "description": "A stable source-redacted failure safe to serialize across public boundaries.",
      "type": "object",
      "properties": {
        "code": {
          "$ref": "#/$defs/ErrorCode"
        },
        "details": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^[a-z0-9_]+$": {
              "$ref": "#/$defs/PublicValue"
            }
          }
        },
        "generation": {
          "anyOf": [
            {
              "$ref": "#/$defs/GenerationId"
            },
            {
              "type": "null"
            }
          ]
        },
        "message": {
          "type": "string",
          "maxLength": 1024
        },
        "next_actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NextAction"
          },
          "maxItems": 8
        },
        "operation": {
          "anyOf": [
            {
              "$ref": "#/$defs/OperationId"
            },
            {
              "type": "null"
            }
          ]
        },
        "repository": {
          "anyOf": [
            {
              "$ref": "#/$defs/RepositoryId"
            },
            {
              "type": "null"
            }
          ]
        },
        "retry_after_ms": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "maximum": 86400000,
          "minimum": 0
        },
        "retryable": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "retryable",
        "details",
        "next_actions"
      ]
    },
    "PublicValue": {
      "description": "Bounded primitive values permitted in public error details.",
      "oneOf": [
        {
          "description": "A boolean property.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "boolean"
            },
            "value": {
              "type": "boolean"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "A signed integer property.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "integer"
            },
            "value": {
              "type": "integer",
              "format": "int64"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "An unsigned integer property.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "unsigned"
            },
            "value": {
              "type": "integer",
              "format": "uint64",
              "maximum": 18446744073709551615,
              "minimum": 0
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "A repository identity.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "repository"
            },
            "value": {
              "$ref": "#/$defs/RepositoryId"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "A generation identity.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "generation"
            },
            "value": {
              "$ref": "#/$defs/GenerationId"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "An operation identity.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "operation"
            },
            "value": {
              "$ref": "#/$defs/OperationId"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "A validated source-free label.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "label"
            },
            "value": {
              "$ref": "#/$defs/SafeLabel"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        }
      ]
    },
    "ReadEnvelope": {
      "description": "Common strict response envelope for generation-pinned reads.",
      "type": "object",
      "properties": {
        "coverage": {
          "description": "Relevant coverage.",
          "$ref": "#/$defs/CoverageSummary"
        },
        "data": {
          "description": "Tool-specific result.",
          "$ref": "#/$defs/CodeDeadData"
        },
        "generation": {
          "description": "Pinned generation and freshness.",
          "$ref": "#/$defs/GenerationSummary"
        },
        "next_cursor": {
          "description": "Safe continuation cursor, when the result is pageable.",
          "$ref": "#/$defs/RequiredNullable2"
        },
        "repository": {
          "description": "Resolved repository.",
          "$ref": "#/$defs/ResolvedRepository"
        },
        "schema_version": {
          "description": "Tool response schema version.",
          "$ref": "#/$defs/SchemaVersion"
        },
        "truncated": {
          "description": "Whether any hard or requested limit stopped completion.",
          "type": "boolean"
        },
        "trust": {
          "description": "Response-level classification for all repository-derived content.",
          "$ref": "#/$defs/TrustClassification"
        },
        "usage": {
          "description": "Runtime resource accounting.",
          "$ref": "#/$defs/UsageSummary"
        },
        "warnings": {
          "description": "Source-free warnings.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/ResponseWarning"
          },
          "maxItems": 100
        }
      },
      "additionalProperties": false,
      "required": [
        "schema_version",
        "repository",
        "generation",
        "coverage",
        "data",
        "truncated",
        "next_cursor",
        "usage",
        "warnings",
        "trust"
      ]
    },
    "RepositoryId": {
      "type": "string",
      "pattern": "^repo1_[a-z2-7]{32}$"
    },
    "RequiredNullable": {
      "description": "A property that must be present and may contain JSON `null`.",
      "anyOf": [
        {
          "$ref": "#/$defs/GenerationId"
        },
        {
          "type": "null"
        }
      ]
    },
    "RequiredNullable2": {
      "description": "A property that must be present and may contain JSON `null`.",
      "anyOf": [
        {
          "$ref": "#/$defs/ContinuationCursor"
        },
        {
          "type": "null"
        }
      ]
    },
    "ResolvedRepository": {
      "description": "Resolved repository metadata.",
      "type": "object",
      "properties": {
        "display_name": {
          "description": "Rootlight-owned display label.",
          "type": "string",
          "maxLength": 256,
          "minLength": 1
        },
        "repository_id": {
          "description": "Stable repository identity.",
          "$ref": "#/$defs/RepositoryId"
        }
      },
      "additionalProperties": false,
      "required": [
        "repository_id",
        "display_name"
      ]
    },
    "ResponseWarning": {
      "description": "Source-free response warning.",
      "type": "object",
      "properties": {
        "code": {
          "description": "Stable warning code.",
          "$ref": "#/$defs/SafeLabel"
        },
        "message": {
          "description": "Rootlight-generated source-free explanation.",
          "$ref": "#/$defs/SourceFreeMessage"
        }
      },
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ]
    },
    "RuleSummary": {
      "description": "One applied false-positive suppression rule.",
      "type": "object",
      "properties": {
        "rule": {
          "description": "Rule identifier or annotation pattern.",
          "type": "string",
          "maxLength": 256,
          "minLength": 1
        },
        "suppressed_count": {
          "description": "Number of symbols suppressed by this rule.",
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "rule",
        "suppressed_count"
      ]
    },
    "SafeLabel": {
      "description": "A short source-free label permitted in public diagnostics.",
      "type": "string",
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "SchemaVersion": {
      "description": "Version marker carried by every first-slice response.",
      "oneOf": [
        {
          "description": "Tool contract version 1.0.",
          "type": "string",
          "const": "1.0"
        }
      ]
    },
    "SourceFreeMessage": {
      "description": "A checked Rootlight-generated message that cannot contain paths or source.",
      "type": "string",
      "maxLength": 1024,
      "minLength": 1,
      "pattern": "^[a-z0-9 -]+$"
    },
    "SourceRef": {
      "description": "A generation-bound reference to immutable repository source.",
      "type": "object",
      "properties": {
        "content_hash": {
          "$ref": "#/$defs/ContentHash"
        },
        "generation": {
          "$ref": "#/$defs/GenerationId"
        },
        "line_hint": {
          "anyOf": [
            {
              "$ref": "#/$defs/LineRange"
            },
            {
              "type": "null"
            }
          ]
        },
        "repository": {
          "$ref": "#/$defs/RepositoryId"
        },
        "span": {
          "$ref": "#/$defs/SourceSpan"
        }
      },
      "additionalProperties": false,
      "required": [
        "repository",
        "generation",
        "span",
        "content_hash"
      ]
    },
    "SourceSpan": {
      "description": "A validated half-open source byte span within one file.",
      "type": "object",
      "properties": {
        "end_byte": {
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "file": {
          "$ref": "#/$defs/FileId"
        },
        "start_byte": {
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "file",
        "start_byte",
        "end_byte"
      ]
    },
    "SymbolId": {
      "type": "string",
      "pattern": "^sym1_[a-z2-7]{39}$"
    },
    "TrustClassification": {
      "description": "Trust classification attached to every future source-bearing value.",
      "oneOf": [
        {
          "description": "Content originated in a repository and must be treated as data.",
          "type": "string",
          "const": "untrusted_repository_data"
        }
      ]
    },
    "UsageSummary": {
      "description": "Bounded counters returned by each read tool.",
      "type": "object",
      "properties": {
        "cache_status": {
          "description": "Cache outcome.",
          "$ref": "#/$defs/CacheStatus"
        },
        "edges": {
          "description": "Relationship edges examined.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "estimated_tokens": {
          "description": "Deterministic token estimate.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "json_bytes": {
          "description": "Encoded structured result bytes.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "rows": {
          "description": "Storage rows examined.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "source_bytes": {
          "description": "Raw source bytes returned.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "trace_id": {
          "description": "Source-free trace identity.",
          "type": "string",
          "maxLength": 128,
          "minLength": 1
        },
        "wall_time_ms": {
          "description": "Cooperative wall time in milliseconds.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "rows",
        "edges",
        "source_bytes",
        "json_bytes",
        "estimated_tokens",
        "wall_time_ms",
        "cache_status",
        "trace_id"
      ]
    }
  }
}
