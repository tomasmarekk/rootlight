{
  "$id": "https://rootlight.local/schema/mcp/architecture.cycles/input/1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArchitectureCyclesInput",
  "description": "Strict input for `architecture.cycles`.",
  "type": "object",
  "properties": {
    "budget": {
      "description": "Optional response limits.",
      "anyOf": [
        {
          "$ref": "#/$defs/ResponseBudget"
        }
      ]
    },
    "generation": {
      "description": "Immutable generation selector.",
      "anyOf": [
        {
          "$ref": "#/$defs/GenerationSelector"
        }
      ]
    },
    "include_self_cycles": {
      "description": "Whether to include self-referential cycles.",
      "type": "boolean"
    },
    "max_cycles": {
      "description": "Maximum returned cycles.",
      "type": "integer",
      "format": "uint16",
      "maximum": 200,
      "minimum": 1
    },
    "min_size": {
      "description": "Minimum cycle size to report.",
      "type": "integer",
      "format": "uint8",
      "maximum": 64,
      "minimum": 2
    },
    "projection": {
      "description": "Relation projection for cycle detection.",
      "$ref": "#/$defs/CycleProjection"
    },
    "rank_by": {
      "description": "Cycle ranking strategy.",
      "anyOf": [
        {
          "$ref": "#/$defs/CycleRankBy"
        }
      ]
    },
    "repository": {
      "description": "Owning repository.",
      "$ref": "#/$defs/RepositorySelector"
    },
    "response_profile": {
      "description": "Requested representation.",
      "anyOf": [
        {
          "$ref": "#/$defs/ResponseProfile"
        }
      ]
    },
    "scope": {
      "description": "Optional structural scope constraint.",
      "anyOf": [
        {
          "$ref": "#/$defs/ScopeSelector"
        }
      ]
    }
  },
  "additionalProperties": false,
  "required": [
    "repository",
    "projection"
  ],
  "$defs": {
    "ActiveGeneration": {
      "description": "Active-generation keyword.",
      "oneOf": [
        {
          "description": "Select the active generation.",
          "type": "string",
          "const": "active"
        }
      ]
    },
    "BuildTargetScope": {
      "description": "Build-target scope.",
      "type": "object",
      "properties": {
        "build_targets": {
          "description": "Distinct build-target identities.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 512,
            "minLength": 1
          },
          "maxItems": 256,
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "required": [
        "build_targets"
      ]
    },
    "CycleProjection": {
      "description": "Relation projection for cycle detection.",
      "type": "object",
      "properties": {
        "level": {
          "description": "Aggregation level for the projection.",
          "type": "string",
          "maxLength": 64,
          "minLength": 1
        },
        "relations": {
          "description": "Relation families included in the projection.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/RelationKind"
          },
          "maxItems": 8,
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "required": [
        "relations",
        "level"
      ]
    },
    "CycleRankBy": {
      "description": "Cycle ranking strategy.",
      "oneOf": [
        {
          "description": "Rank by cycle size.",
          "type": "string",
          "const": "size"
        },
        {
          "description": "Rank by aggregate edge weight.",
          "type": "string",
          "const": "edge_weight"
        },
        {
          "description": "Rank by change risk signal.",
          "type": "string",
          "const": "change_risk"
        },
        {
          "description": "Rank by estimated break cost.",
          "type": "string",
          "const": "break_cost"
        }
      ]
    },
    "GenerationId": {
      "type": "string",
      "pattern": "^gen1_[a-z2-7]{39}$"
    },
    "GenerationSelector": {
      "description": "Generation selector shared by first-slice read tools.",
      "anyOf": [
        {
          "description": "Resolve the currently active immutable generation.",
          "$ref": "#/$defs/ActiveGeneration"
        },
        {
          "description": "Pin an explicit immutable generation.",
          "$ref": "#/$defs/GenerationId"
        }
      ]
    },
    "PackageScope": {
      "description": "Package scope.",
      "type": "object",
      "properties": {
        "packages": {
          "description": "Distinct package identities.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 512,
            "minLength": 1
          },
          "maxItems": 256,
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "required": [
        "packages"
      ]
    },
    "PathScope": {
      "description": "Repository-relative path scope.",
      "type": "object",
      "properties": {
        "paths": {
          "description": "Distinct repository-relative paths.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 8192,
            "minLength": 1
          },
          "maxItems": 256,
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "required": [
        "paths"
      ]
    },
    "ProvenanceLevel": {
      "description": "Provenance detail requested by a read tool.",
      "oneOf": [
        {
          "description": "Omit provenance detail beyond mandatory source identity.",
          "type": "string",
          "const": "none"
        },
        {
          "description": "Return compact provider and confidence evidence.",
          "type": "string",
          "const": "compact"
        },
        {
          "description": "Return maximum bounded provenance evidence.",
          "type": "string",
          "const": "full"
        }
      ]
    },
    "RelationKind": {
      "description": "Typed relation families accepted by intent tools.",
      "oneOf": [
        {
          "description": "Direct outbound call.",
          "type": "string",
          "const": "calls"
        },
        {
          "description": "Inbound caller.",
          "type": "string",
          "const": "called_by"
        },
        {
          "description": "Symbol reference or usage.",
          "type": "string",
          "const": "references"
        },
        {
          "description": "Type dependency or type-of relation.",
          "type": "string",
          "const": "types"
        },
        {
          "description": "Trait or interface implementation.",
          "type": "string",
          "const": "implements"
        },
        {
          "description": "Import or module dependency.",
          "type": "string",
          "const": "imports"
        },
        {
          "description": "Test coverage relation.",
          "type": "string",
          "const": "tests"
        },
        {
          "description": "Code ownership or authorship.",
          "type": "string",
          "const": "ownership"
        },
        {
          "description": "Service or RPC call.",
          "type": "string",
          "const": "service_call"
        },
        {
          "description": "HTTP route invocation.",
          "type": "string",
          "const": "calls_route"
        },
        {
          "description": "Message publish or consume.",
          "type": "string",
          "const": "messaging"
        },
        {
          "description": "Database table read.",
          "type": "string",
          "const": "reads_table"
        },
        {
          "description": "Database table write.",
          "type": "string",
          "const": "writes_table"
        },
        {
          "description": "Build or compilation dependency.",
          "type": "string",
          "const": "build_dependency"
        },
        {
          "description": "Data flow propagation.",
          "type": "string",
          "const": "data_flow"
        },
        {
          "description": "Co-change history signal.",
          "type": "string",
          "const": "history"
        }
      ]
    },
    "RepositoryAliasSelector": {
      "description": "Registered repository-alias selector.",
      "type": "object",
      "properties": {
        "alias": {
          "description": "Registered alias, resolved to exactly one repository.",
          "type": "string",
          "maxLength": 256,
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "alias"
      ]
    },
    "RepositoryId": {
      "type": "string",
      "pattern": "^repo1_[a-z2-7]{32}$"
    },
    "RepositoryIdSelector": {
      "description": "Stable repository-ID selector.",
      "type": "object",
      "properties": {
        "repository_id": {
          "description": "Repository identity.",
          "$ref": "#/$defs/RepositoryId"
        }
      },
      "additionalProperties": false,
      "required": [
        "repository_id"
      ]
    },
    "RepositorySelector": {
      "description": "Repository selector accepted by first-slice read tools.",
      "anyOf": [
        {
          "description": "Select by stable repository identifier.",
          "$ref": "#/$defs/RepositoryIdSelector"
        },
        {
          "description": "Select by a configured local alias.",
          "$ref": "#/$defs/RepositoryAliasSelector"
        }
      ]
    },
    "ResponseBudget": {
      "description": "Optional response limits that can only reduce server hard limits.",
      "type": "object",
      "properties": {
        "evidence_level": {
          "description": "Requested evidence detail.",
          "anyOf": [
            {
              "$ref": "#/$defs/ProvenanceLevel"
            }
          ]
        },
        "max_depth": {
          "description": "Maximum plan depth.",
          "type": "integer",
          "format": "uint8",
          "maximum": 16,
          "minimum": 1
        },
        "max_paths": {
          "description": "Maximum independently returned paths.",
          "type": "integer",
          "format": "uint16",
          "maximum": 1000,
          "minimum": 1
        },
        "max_results": {
          "description": "Maximum returned result objects.",
          "type": "integer",
          "format": "uint16",
          "maximum": 1000,
          "minimum": 1
        },
        "max_source_bytes": {
          "description": "Maximum source bytes before JSON escaping.",
          "type": "integer",
          "format": "uint32",
          "maximum": 524288,
          "minimum": 1
        },
        "max_tokens": {
          "description": "Maximum estimated output tokens.\n\nThe schema ceiling is the largest aggregate budget any tool accepts\n(`query.batch` allows up to 16000); the server clamps each request to\nthe calling tool's own hard limit.",
          "type": "integer",
          "format": "uint16",
          "maximum": 16000,
          "minimum": 100
        },
        "max_traversal_facts": {
          "description": "Maximum relationship or traversal facts examined.",
          "type": "integer",
          "format": "uint32",
          "maximum": 100000,
          "minimum": 1
        },
        "timeout_ms": {
          "description": "Cooperative request deadline in milliseconds.",
          "type": "integer",
          "format": "uint32",
          "maximum": 30000,
          "minimum": 10
        }
      },
      "additionalProperties": false
    },
    "ResponseProfile": {
      "description": "Requested response representation.",
      "oneOf": [
        {
          "description": "Smallest complete correctness-bearing response.",
          "type": "string",
          "const": "compact"
        },
        {
          "description": "More explanatory response within the same hard budgets.",
          "type": "string",
          "const": "standard"
        },
        {
          "description": "Maximum bounded provenance and evidence.",
          "type": "string",
          "const": "evidence"
        }
      ]
    },
    "ScopeSelector": {
      "description": "Common scope selector for read tools.",
      "anyOf": [
        {
          "description": "Limit to repository-relative paths.",
          "$ref": "#/$defs/PathScope"
        },
        {
          "description": "Limit to packages.",
          "$ref": "#/$defs/PackageScope"
        },
        {
          "description": "Limit to build targets.",
          "$ref": "#/$defs/BuildTargetScope"
        },
        {
          "description": "Limit to stable symbols.",
          "$ref": "#/$defs/SymbolScope"
        }
      ]
    },
    "SymbolId": {
      "type": "string",
      "pattern": "^sym1_[a-z2-7]{39}$"
    },
    "SymbolScope": {
      "description": "Stable-symbol scope.",
      "type": "object",
      "properties": {
        "symbols": {
          "description": "Distinct symbol identities.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/SymbolId"
          },
          "maxItems": 64,
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "required": [
        "symbols"
      ]
    }
  }
}
