{
  "$id": "https://rootlight.local/schema/mcp/repo.status/input/1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RepoStatusInput",
  "description": "Strict input for `repo.status`.",
  "type": "object",
  "properties": {
    "budget": {
      "description": "Optional response limits.",
      "anyOf": [
        {
          "$ref": "#/$defs/ResponseBudget"
        }
      ]
    },
    "coverage_detail": {
      "description": "Requested coverage granularity.",
      "anyOf": [
        {
          "$ref": "#/$defs/CoverageDetail"
        }
      ]
    },
    "explain": {
      "description": "Return the bounded plan without executing retrieval.",
      "type": "boolean"
    },
    "generation": {
      "description": "Active or explicit generation selector.",
      "anyOf": [
        {
          "$ref": "#/$defs/GenerationSelector"
        }
      ]
    },
    "include_operations": {
      "description": "Include active and most recent operations.",
      "type": "boolean"
    },
    "repository": {
      "description": "Repository to inspect.",
      "$ref": "#/$defs/RepositorySelector"
    },
    "require_freshness": {
      "description": "Minimum freshness requirement for the response.",
      "anyOf": [
        {
          "$ref": "#/$defs/FreshnessRequirement"
        }
      ]
    },
    "response_profile": {
      "description": "Requested evidence detail.",
      "anyOf": [
        {
          "$ref": "#/$defs/ResponseProfile"
        }
      ]
    }
  },
  "additionalProperties": false,
  "required": [
    "repository"
  ],
  "$defs": {
    "ActiveGeneration": {
      "description": "Active-generation keyword.",
      "oneOf": [
        {
          "description": "Select the active generation.",
          "type": "string",
          "const": "active"
        }
      ]
    },
    "CoverageDetail": {
      "description": "Requested coverage reporting granularity.",
      "oneOf": [
        {
          "description": "Aggregate status only.",
          "type": "string",
          "const": "summary"
        },
        {
          "description": "Per-language tier and file counts.",
          "type": "string",
          "const": "language"
        },
        {
          "description": "Per-project or package breakdown.",
          "type": "string",
          "const": "project"
        },
        {
          "description": "Per-file coverage rows, requires a scope.",
          "type": "string",
          "const": "file"
        }
      ]
    },
    "FreshnessRequirement": {
      "description": "Minimum freshness the caller requires before the response is useful.",
      "oneOf": [
        {
          "description": "No freshness requirement.",
          "type": "string",
          "const": "none"
        },
        {
          "description": "Structural tier must be fresh.",
          "type": "string",
          "const": "structural"
        },
        {
          "description": "Semantic tier must be fresh.",
          "type": "string",
          "const": "semantic"
        }
      ]
    },
    "GenerationId": {
      "type": "string",
      "pattern": "^gen1_[a-z2-7]{39}$"
    },
    "GenerationSelector": {
      "description": "Generation selector shared by first-slice read tools.",
      "anyOf": [
        {
          "description": "Resolve the currently active immutable generation.",
          "$ref": "#/$defs/ActiveGeneration"
        },
        {
          "description": "Pin an explicit immutable generation.",
          "$ref": "#/$defs/GenerationId"
        }
      ]
    },
    "ProvenanceLevel": {
      "description": "Provenance detail requested by a read tool.",
      "oneOf": [
        {
          "description": "Omit provenance detail beyond mandatory source identity.",
          "type": "string",
          "const": "none"
        },
        {
          "description": "Return compact provider and confidence evidence.",
          "type": "string",
          "const": "compact"
        },
        {
          "description": "Return maximum bounded provenance evidence.",
          "type": "string",
          "const": "full"
        }
      ]
    },
    "RepositoryAliasSelector": {
      "description": "Registered repository-alias selector.",
      "type": "object",
      "properties": {
        "alias": {
          "description": "Registered alias, resolved to exactly one repository.",
          "type": "string",
          "maxLength": 256,
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "alias"
      ]
    },
    "RepositoryId": {
      "type": "string",
      "pattern": "^repo1_[a-z2-7]{32}$"
    },
    "RepositoryIdSelector": {
      "description": "Stable repository-ID selector.",
      "type": "object",
      "properties": {
        "repository_id": {
          "description": "Repository identity.",
          "$ref": "#/$defs/RepositoryId"
        }
      },
      "additionalProperties": false,
      "required": [
        "repository_id"
      ]
    },
    "RepositorySelector": {
      "description": "Repository selector accepted by first-slice read tools.",
      "anyOf": [
        {
          "description": "Select by stable repository identifier.",
          "$ref": "#/$defs/RepositoryIdSelector"
        },
        {
          "description": "Select by a configured local alias.",
          "$ref": "#/$defs/RepositoryAliasSelector"
        }
      ]
    },
    "ResponseBudget": {
      "description": "Optional response limits that can only reduce server hard limits.",
      "type": "object",
      "properties": {
        "evidence_level": {
          "description": "Requested evidence detail.",
          "anyOf": [
            {
              "$ref": "#/$defs/ProvenanceLevel"
            }
          ]
        },
        "max_depth": {
          "description": "Maximum plan depth.",
          "type": "integer",
          "format": "uint8",
          "maximum": 16,
          "minimum": 1
        },
        "max_paths": {
          "description": "Maximum independently returned paths.",
          "type": "integer",
          "format": "uint16",
          "maximum": 1000,
          "minimum": 1
        },
        "max_results": {
          "description": "Maximum returned result objects.",
          "type": "integer",
          "format": "uint16",
          "maximum": 1000,
          "minimum": 1
        },
        "max_source_bytes": {
          "description": "Maximum source bytes before JSON escaping.",
          "type": "integer",
          "format": "uint32",
          "maximum": 524288,
          "minimum": 1
        },
        "max_tokens": {
          "description": "Maximum estimated output tokens.\n\nThe schema ceiling is the largest aggregate budget any tool accepts\n(`query.batch` allows up to 16000); the server clamps each request to\nthe calling tool's own hard limit.",
          "type": "integer",
          "format": "uint16",
          "maximum": 16000,
          "minimum": 100
        },
        "max_traversal_facts": {
          "description": "Maximum relationship or traversal facts examined.",
          "type": "integer",
          "format": "uint32",
          "maximum": 100000,
          "minimum": 1
        },
        "timeout_ms": {
          "description": "Cooperative request deadline in milliseconds.",
          "type": "integer",
          "format": "uint32",
          "maximum": 30000,
          "minimum": 10
        }
      },
      "additionalProperties": false
    },
    "ResponseProfile": {
      "description": "Requested response representation.",
      "oneOf": [
        {
          "description": "Smallest complete correctness-bearing response.",
          "type": "string",
          "const": "compact"
        },
        {
          "description": "More explanatory response within the same hard budgets.",
          "type": "string",
          "const": "standard"
        },
        {
          "description": "Maximum bounded provenance and evidence.",
          "type": "string",
          "const": "evidence"
        }
      ]
    }
  }
}
