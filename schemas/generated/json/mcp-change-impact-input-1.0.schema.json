{
  "$id": "https://rootlight.local/schema/mcp/change.impact/input/1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChangeImpactInput",
  "description": "Strict input for `change.impact`.",
  "type": "object",
  "properties": {
    "budget": {
      "description": "Response budget overrides.",
      "anyOf": [
        {
          "$ref": "#/$defs/ResponseBudget"
        }
      ]
    },
    "change": {
      "description": "The change set to map.",
      "$ref": "#/$defs/ChangeSelector"
    },
    "generation": {
      "description": "Generation to analyze against.",
      "anyOf": [
        {
          "$ref": "#/$defs/GenerationSelector"
        }
      ]
    },
    "include_history": {
      "description": "Whether to include bounded history signals.",
      "type": "boolean"
    },
    "include_tests": {
      "description": "Whether to include test candidates.",
      "type": "boolean"
    },
    "max_depth": {
      "description": "Maximum transitive depth.",
      "type": "integer",
      "format": "uint8",
      "maximum": 8,
      "minimum": 1
    },
    "min_confidence": {
      "description": "Minimum confidence for propagation inclusion.",
      "type": "integer",
      "format": "uint16",
      "maximum": 1000,
      "minimum": 0
    },
    "profile": {
      "description": "Requested response profile.",
      "anyOf": [
        {
          "$ref": "#/$defs/ResponseProfile"
        }
      ]
    },
    "relation_policy": {
      "description": "Relation propagation policy.",
      "anyOf": [
        {
          "$ref": "#/$defs/RelationPolicy"
        }
      ]
    },
    "repository": {
      "description": "Repository or workspace selector.",
      "$ref": "#/$defs/RepositorySelector"
    },
    "scope": {
      "description": "Optional scope bounding.",
      "anyOf": [
        {
          "$ref": "#/$defs/ImpactScope"
        }
      ]
    }
  },
  "additionalProperties": false,
  "required": [
    "repository",
    "change"
  ],
  "$defs": {
    "ActiveGeneration": {
      "description": "Active-generation keyword.",
      "oneOf": [
        {
          "description": "Select the active generation.",
          "type": "string",
          "const": "active"
        }
      ]
    },
    "ChangeSelector": {
      "description": "Selector for the change set to analyze.",
      "type": "object",
      "properties": {
        "paths": {
          "description": "Explicit file paths known to be changed.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 8192,
            "minLength": 1
          },
          "maxItems": 1000,
          "minItems": 1
        },
        "revision_range": {
          "description": "Explicit Git revision range.",
          "type": "string",
          "maxLength": 512,
          "minLength": 1
        },
        "symbol_ids": {
          "description": "Explicit symbol identifiers known to be changed.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/SymbolId"
          },
          "maxItems": 256,
          "minItems": 1
        },
        "working_tree": {
          "description": "Working-tree state to diff.",
          "anyOf": [
            {
              "$ref": "#/$defs/WorkingTreeState"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "GenerationId": {
      "type": "string",
      "pattern": "^gen1_[a-z2-7]{39}$"
    },
    "GenerationSelector": {
      "description": "Generation selector shared by first-slice read tools.",
      "anyOf": [
        {
          "description": "Resolve the currently active immutable generation.",
          "$ref": "#/$defs/ActiveGeneration"
        },
        {
          "description": "Pin an explicit immutable generation.",
          "$ref": "#/$defs/GenerationId"
        }
      ]
    },
    "ImpactScope": {
      "description": "Scope bounding for impact analysis.",
      "type": "object",
      "properties": {
        "packages": {
          "description": "Restrict to these package identities.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 512,
            "minLength": 1
          },
          "maxItems": 128,
          "minItems": 1
        },
        "paths": {
          "description": "Restrict to these repository-relative paths.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 8192,
            "minLength": 1
          },
          "maxItems": 256,
          "minItems": 1
        },
        "services": {
          "description": "Restrict to these service identities.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 512,
            "minLength": 1
          },
          "maxItems": 64,
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "ProvenanceLevel": {
      "description": "Provenance detail requested by a read tool.",
      "oneOf": [
        {
          "description": "Omit provenance detail beyond mandatory source identity.",
          "type": "string",
          "const": "none"
        },
        {
          "description": "Return compact provider and confidence evidence.",
          "type": "string",
          "const": "compact"
        },
        {
          "description": "Return maximum bounded provenance evidence.",
          "type": "string",
          "const": "full"
        }
      ]
    },
    "RelationPolicy": {
      "description": "Relation propagation policy for impact analysis.",
      "oneOf": [
        {
          "description": "Default balanced propagation.",
          "type": "string",
          "const": "standard"
        },
        {
          "description": "Over-approximate to avoid missing dependents.",
          "type": "string",
          "const": "conservative"
        },
        {
          "description": "Only direct dependents, no transitive closure.",
          "type": "string",
          "const": "direct_only"
        }
      ]
    },
    "RepositoryAliasSelector": {
      "description": "Registered repository-alias selector.",
      "type": "object",
      "properties": {
        "alias": {
          "description": "Registered alias, resolved to exactly one repository.",
          "type": "string",
          "maxLength": 256,
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "alias"
      ]
    },
    "RepositoryId": {
      "type": "string",
      "pattern": "^repo1_[a-z2-7]{32}$"
    },
    "RepositoryIdSelector": {
      "description": "Stable repository-ID selector.",
      "type": "object",
      "properties": {
        "repository_id": {
          "description": "Repository identity.",
          "$ref": "#/$defs/RepositoryId"
        }
      },
      "additionalProperties": false,
      "required": [
        "repository_id"
      ]
    },
    "RepositorySelector": {
      "description": "Repository selector accepted by first-slice read tools.",
      "anyOf": [
        {
          "description": "Select by stable repository identifier.",
          "$ref": "#/$defs/RepositoryIdSelector"
        },
        {
          "description": "Select by a configured local alias.",
          "$ref": "#/$defs/RepositoryAliasSelector"
        }
      ]
    },
    "ResponseBudget": {
      "description": "Optional response limits that can only reduce server hard limits.",
      "type": "object",
      "properties": {
        "evidence_level": {
          "description": "Requested evidence detail.",
          "anyOf": [
            {
              "$ref": "#/$defs/ProvenanceLevel"
            }
          ]
        },
        "max_depth": {
          "description": "Maximum plan depth.",
          "type": "integer",
          "format": "uint8",
          "maximum": 16,
          "minimum": 1
        },
        "max_paths": {
          "description": "Maximum independently returned paths.",
          "type": "integer",
          "format": "uint16",
          "maximum": 1000,
          "minimum": 1
        },
        "max_results": {
          "description": "Maximum returned result objects.",
          "type": "integer",
          "format": "uint16",
          "maximum": 1000,
          "minimum": 1
        },
        "max_source_bytes": {
          "description": "Maximum source bytes before JSON escaping.",
          "type": "integer",
          "format": "uint32",
          "maximum": 524288,
          "minimum": 1
        },
        "max_tokens": {
          "description": "Maximum estimated output tokens.\n\nThe schema ceiling is the largest aggregate budget any tool accepts\n(`query.batch` allows up to 16000); the server clamps each request to\nthe calling tool's own hard limit.",
          "type": "integer",
          "format": "uint16",
          "maximum": 16000,
          "minimum": 100
        },
        "max_traversal_facts": {
          "description": "Maximum relationship or traversal facts examined.",
          "type": "integer",
          "format": "uint32",
          "maximum": 100000,
          "minimum": 1
        },
        "timeout_ms": {
          "description": "Cooperative request deadline in milliseconds.",
          "type": "integer",
          "format": "uint32",
          "maximum": 30000,
          "minimum": 10
        }
      },
      "additionalProperties": false
    },
    "ResponseProfile": {
      "description": "Requested response representation.",
      "oneOf": [
        {
          "description": "Smallest complete correctness-bearing response.",
          "type": "string",
          "const": "compact"
        },
        {
          "description": "More explanatory response within the same hard budgets.",
          "type": "string",
          "const": "standard"
        },
        {
          "description": "Maximum bounded provenance and evidence.",
          "type": "string",
          "const": "evidence"
        }
      ]
    },
    "SymbolId": {
      "type": "string",
      "pattern": "^sym1_[a-z2-7]{39}$"
    },
    "WorkingTreeState": {
      "description": "Working-tree diff state.",
      "oneOf": [
        {
          "description": "Unstaged changes only.",
          "type": "string",
          "const": "unstaged"
        },
        {
          "description": "Staged changes only.",
          "type": "string",
          "const": "staged"
        },
        {
          "description": "All working-tree changes including staged.",
          "type": "string",
          "const": "all"
        }
      ]
    }
  }
}
