{
  "$id": "https://rootlight.local/schema/mcp/change.impact/output/1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ToolResponse",
  "description": "A checked success-or-error result accepted by one tool output schema.\n\nSuccessful variants preserve each tool's documented response shape.\nExpected domain failures use the same versioned [`ErrorResponse`] and\nchecked [`PublicError`] contract for every tool.",
  "type": "object",
  "anyOf": [
    {
      "description": "A tool-specific successful response.",
      "$ref": "#/$defs/ReadEnvelope"
    },
    {
      "description": "A versioned source-redacted domain error.",
      "$ref": "#/$defs/ErrorResponse"
    }
  ],
  "unevaluatedProperties": false,
  "$defs": {
    "AnalysisTier": {
      "description": "Requested or observed language support tier.",
      "oneOf": [
        {
          "description": "Compiler-quality or equivalent semantic evidence.",
          "type": "string",
          "const": "A"
        },
        {
          "description": "High-confidence partial semantic evidence.",
          "type": "string",
          "const": "B"
        },
        {
          "description": "Generic structural extraction.",
          "type": "string",
          "const": "C"
        },
        {
          "description": "Lexical-only support.",
          "type": "string",
          "const": "D"
        }
      ]
    },
    "CacheStatus": {
      "description": "Cache classification for usage reporting.",
      "oneOf": [
        {
          "description": "No cache entry was used.",
          "type": "string",
          "const": "miss"
        },
        {
          "description": "A verified generation-bound cache entry was used.",
          "type": "string",
          "const": "hit"
        },
        {
          "description": "The operator does not use a cache.",
          "type": "string",
          "const": "not_applicable"
        }
      ]
    },
    "ChangeClassification": {
      "description": "Classification of a resolved change span.",
      "oneOf": [
        {
          "description": "Public API surface was modified.",
          "type": "string",
          "const": "surface"
        },
        {
          "description": "Internal implementation body was modified.",
          "type": "string",
          "const": "body"
        },
        {
          "description": "A new entity was added.",
          "type": "string",
          "const": "added"
        },
        {
          "description": "An entity was removed.",
          "type": "string",
          "const": "removed"
        },
        {
          "description": "An entity was renamed or moved.",
          "type": "string",
          "const": "renamed"
        }
      ]
    },
    "ChangeImpactData": {
      "description": "`change.impact` result data.",
      "type": "object",
      "properties": {
        "impacted": {
          "description": "Ranked impact groups.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/ImpactGroup"
          },
          "maxItems": 1256
        },
        "resolved_changes": {
          "description": "Resolved changes from the input change set.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/ResolvedChange"
          },
          "maxItems": 1256,
          "minItems": 1
        },
        "risk_summary": {
          "description": "Aggregate risk summary.",
          "$ref": "#/$defs/ImpactRiskSummary"
        },
        "service_impacts": {
          "description": "Cross-service and cross-repository effects.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/ServiceImpact"
          },
          "maxItems": 128
        },
        "tests": {
          "description": "Test candidates when requested.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/TestCandidate"
          },
          "maxItems": 500
        }
      },
      "additionalProperties": false,
      "required": [
        "resolved_changes",
        "impacted",
        "service_impacts",
        "tests",
        "risk_summary"
      ]
    },
    "ContinuationCursor": {
      "description": "A bounded opaque continuation cursor.",
      "type": "string",
      "maxLength": 4096,
      "minLength": 1
    },
    "CoverageStatus": {
      "description": "Completeness of a bounded fact or result set.",
      "oneOf": [
        {
          "description": "The declared domain was completely analyzed.",
          "type": "string",
          "const": "complete"
        },
        {
          "description": "A documented bound truncated the domain.",
          "type": "string",
          "const": "bounded"
        },
        {
          "description": "A representative sample was analyzed.",
          "type": "string",
          "const": "sampled"
        },
        {
          "description": "Completeness could not be established.",
          "type": "string",
          "const": "unknown"
        }
      ]
    },
    "CoverageSummary": {
      "description": "Coverage metadata relevant to one query.",
      "type": "object",
      "properties": {
        "languages": {
          "description": "Deterministically ordered language coverage.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/LanguageCoverage"
          },
          "maxItems": 64
        },
        "skipped_inputs": {
          "description": "Inputs skipped by policy, limits, or capability.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "status": {
          "description": "Aggregate query-domain coverage.",
          "$ref": "#/$defs/CoverageStatus"
        }
      },
      "additionalProperties": false,
      "required": [
        "status",
        "languages",
        "skipped_inputs"
      ]
    },
    "DetailKey": {
      "description": "A validated key for a bounded public error detail.",
      "type": "string",
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^[a-z0-9_]+$"
    },
    "EntityKind": {
      "description": "A closed common entity kind understood by the Rootlight core.",
      "oneOf": [
        {
          "description": "A repository root.",
          "type": "string",
          "const": "repository"
        },
        {
          "description": "A checked-out worktree.",
          "type": "string",
          "const": "worktree"
        },
        {
          "description": "A package or distribution unit.",
          "type": "string",
          "const": "package"
        },
        {
          "description": "A configuration-specific build target.",
          "type": "string",
          "const": "build_target"
        },
        {
          "description": "A physical directory.",
          "type": "string",
          "const": "directory"
        },
        {
          "description": "An immutable generation file.",
          "type": "string",
          "const": "file"
        },
        {
          "description": "A language module.",
          "type": "string",
          "const": "module"
        },
        {
          "description": "A language namespace.",
          "type": "string",
          "const": "namespace"
        },
        {
          "description": "A class-like type.",
          "type": "string",
          "const": "class"
        },
        {
          "description": "A struct-like type.",
          "type": "string",
          "const": "struct"
        },
        {
          "description": "An enumeration.",
          "type": "string",
          "const": "enum"
        },
        {
          "description": "A union type.",
          "type": "string",
          "const": "union"
        },
        {
          "description": "A type alias.",
          "type": "string",
          "const": "type_alias"
        },
        {
          "description": "A trait.",
          "type": "string",
          "const": "trait"
        },
        {
          "description": "An interface.",
          "type": "string",
          "const": "interface"
        },
        {
          "description": "A protocol.",
          "type": "string",
          "const": "protocol"
        },
        {
          "description": "A free function.",
          "type": "string",
          "const": "function"
        },
        {
          "description": "A method.",
          "type": "string",
          "const": "method"
        },
        {
          "description": "A constructor.",
          "type": "string",
          "const": "constructor"
        },
        {
          "description": "A closure.",
          "type": "string",
          "const": "closure"
        },
        {
          "description": "A field.",
          "type": "string",
          "const": "field"
        },
        {
          "description": "A property.",
          "type": "string",
          "const": "property"
        },
        {
          "description": "A constant.",
          "type": "string",
          "const": "constant"
        },
        {
          "description": "A variable.",
          "type": "string",
          "const": "variable"
        },
        {
          "description": "A callable parameter.",
          "type": "string",
          "const": "parameter"
        },
        {
          "description": "A type parameter.",
          "type": "string",
          "const": "type_parameter"
        },
        {
          "description": "An import clause.",
          "type": "string",
          "const": "import"
        },
        {
          "description": "An export clause.",
          "type": "string",
          "const": "export"
        },
        {
          "description": "A service route or endpoint.",
          "type": "string",
          "const": "route"
        },
        {
          "description": "A service boundary.",
          "type": "string",
          "const": "service"
        },
        {
          "description": "A message topic or queue.",
          "type": "string",
          "const": "message_topic"
        },
        {
          "description": "A database object.",
          "type": "string",
          "const": "database_object"
        },
        {
          "description": "A test declaration.",
          "type": "string",
          "const": "test"
        },
        {
          "description": "A configuration key.",
          "type": "string",
          "const": "configuration_key"
        },
        {
          "description": "A source-control commit.",
          "type": "string",
          "const": "commit"
        },
        {
          "description": "A source-control change.",
          "type": "string",
          "const": "change"
        },
        {
          "description": "A derived architecture community.",
          "type": "string",
          "const": "community_view"
        },
        {
          "description": "A symbol outside the indexed repository.",
          "type": "string",
          "const": "external_symbol"
        }
      ]
    },
    "ErrorCode": {
      "description": "Stable public error families shared by all Rootlight boundaries.",
      "oneOf": [
        {
          "description": "The caller supplied an invalid value.",
          "type": "string",
          "const": "INVALID_ARGUMENT"
        },
        {
          "description": "The requested entity does not exist.",
          "type": "string",
          "const": "NOT_FOUND"
        },
        {
          "description": "The request conflicts with current state.",
          "type": "string",
          "const": "CONFLICT"
        },
        {
          "description": "The selected generation is no longer valid for this operation.",
          "type": "string",
          "const": "STALE_GENERATION"
        },
        {
          "description": "The requested capability is unavailable.",
          "type": "string",
          "const": "UNSUPPORTED_CAPABILITY"
        },
        {
          "description": "The result is incomplete for the requested coverage.",
          "type": "string",
          "const": "INCOMPLETE_COVERAGE"
        },
        {
          "description": "The operation exceeded an explicit work budget.",
          "type": "string",
          "const": "BUDGET_EXCEEDED"
        },
        {
          "description": "A bounded resource is exhausted.",
          "type": "string",
          "const": "RESOURCE_EXHAUSTED"
        },
        {
          "description": "The operation was cancelled before completion.",
          "type": "string",
          "const": "CANCELLED"
        },
        {
          "description": "An isolated adapter failed.",
          "type": "string",
          "const": "ADAPTER_FAILED"
        },
        {
          "description": "An index failed integrity checks.",
          "type": "string",
          "const": "INDEX_CORRUPT"
        },
        {
          "description": "Stored data requires a supported migration.",
          "type": "string",
          "const": "MIGRATION_REQUIRED"
        },
        {
          "description": "Policy denied the requested operation.",
          "type": "string",
          "const": "PERMISSION_DENIED"
        },
        {
          "description": "A protocol or contract version is incompatible.",
          "type": "string",
          "const": "PROTOCOL_MISMATCH"
        },
        {
          "description": "A conflicting operation temporarily owns the resource.",
          "type": "string",
          "const": "BUSY"
        },
        {
          "description": "An internal failure cannot be safely disclosed.",
          "type": "string",
          "const": "INTERNAL"
        },
        {
          "description": "A pagination cursor is invalid, expired, forged, or context-mismatched.",
          "type": "string",
          "const": "INVALID_CURSOR"
        },
        {
          "description": "A supplied value has the wrong type for its target field.",
          "type": "string",
          "const": "TYPE_MISMATCH"
        },
        {
          "description": "The request exceeded a cost limit before execution.",
          "type": "string",
          "const": "COST_LIMIT"
        },
        {
          "description": "The query uses an operator outside the documented allowlist.",
          "type": "string",
          "const": "OPERATOR_FORBIDDEN"
        },
        {
          "description": "A batch binding reference is malformed or unresolved.",
          "type": "string",
          "const": "BINDING_INVALID"
        },
        {
          "description": "A batch binding produced a value of the wrong type for its target.",
          "type": "string",
          "const": "BINDING_TYPE_MISMATCH"
        }
      ]
    },
    "ErrorResponse": {
      "description": "Strict common error response for MCP contract failures.",
      "type": "object",
      "properties": {
        "error": {
          "description": "Stable public error envelope.",
          "$ref": "#/$defs/PublicError"
        },
        "schema_version": {
          "description": "Tool error schema version.",
          "$ref": "#/$defs/SchemaVersion"
        }
      },
      "additionalProperties": false,
      "required": [
        "schema_version",
        "error"
      ]
    },
    "FileId": {
      "type": "string",
      "pattern": "^file1_[a-z2-7]{39}$"
    },
    "Freshness": {
      "description": "Freshness of one immutable generation.",
      "oneOf": [
        {
          "description": "Matches the currently observed repository snapshot.",
          "type": "string",
          "const": "current"
        },
        {
          "description": "Queryable but a newer generation exists.",
          "type": "string",
          "const": "superseded"
        },
        {
          "description": "Queryable with a known stale source snapshot.",
          "type": "string",
          "const": "stale"
        }
      ]
    },
    "GenerationId": {
      "type": "string",
      "pattern": "^gen1_[a-z2-7]{39}$"
    },
    "GenerationSummary": {
      "description": "Generation metadata carried by each read response.",
      "type": "object",
      "properties": {
        "generation_id": {
          "description": "Pinned generation.",
          "$ref": "#/$defs/GenerationId"
        },
        "parent_generation": {
          "description": "Parent generation, if any.",
          "$ref": "#/$defs/RequiredNullable"
        },
        "semantic_freshness": {
          "description": "Semantic freshness.",
          "$ref": "#/$defs/Freshness"
        },
        "structural_freshness": {
          "description": "Structural freshness.",
          "$ref": "#/$defs/Freshness"
        }
      },
      "additionalProperties": false,
      "required": [
        "generation_id",
        "parent_generation",
        "structural_freshness",
        "semantic_freshness"
      ]
    },
    "ImpactEntry": {
      "description": "One impacted dependent with path rationale.",
      "type": "object",
      "properties": {
        "confidence": {
          "description": "Confidence in the impact path, 0 through 1000.",
          "type": "integer",
          "format": "uint16",
          "maximum": 1000,
          "minimum": 0
        },
        "distance": {
          "description": "Transitive distance from the change.",
          "type": "integer",
          "format": "uint8",
          "maximum": 8,
          "minimum": 1
        },
        "is_public": {
          "description": "Whether this dependent is a public surface.",
          "type": "boolean"
        },
        "kind": {
          "description": "Entity kind of the affected symbol.",
          "$ref": "#/$defs/EntityKind"
        },
        "symbol_id": {
          "description": "Affected symbol identity.",
          "$ref": "#/$defs/SymbolId"
        },
        "via": {
          "description": "Relation predicates forming the impact path.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 128,
            "minLength": 1
          },
          "maxItems": 16,
          "minItems": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "symbol_id",
        "kind",
        "distance",
        "confidence",
        "via",
        "is_public"
      ]
    },
    "ImpactGroup": {
      "description": "One grouped set of impacted dependents.",
      "type": "object",
      "properties": {
        "dependents": {
          "description": "Ranked dependents.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/ImpactEntry"
          },
          "maxItems": 500
        },
        "source_index": {
          "description": "The originating resolved change.",
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "source_index",
        "dependents"
      ]
    },
    "ImpactRiskSummary": {
      "description": "Aggregate risk summary for the impact result.",
      "type": "object",
      "properties": {
        "breaking_surface": {
          "description": "Whether public surface was changed.",
          "type": "boolean"
        },
        "coverage": {
          "description": "Coverage status of the impact analysis.",
          "$ref": "#/$defs/CoverageStatus"
        },
        "dynamic_blind_spots": {
          "description": "Whether dynamic or reflection-based relations create blind spots.",
          "type": "boolean"
        },
        "fanout": {
          "description": "Total transitive fanout count.",
          "type": "integer",
          "format": "uint32",
          "maximum": 100000,
          "minimum": 0
        },
        "level": {
          "description": "Aggregate risk level.",
          "$ref": "#/$defs/RiskLevel"
        },
        "reasons": {
          "description": "Source-free reason codes.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 128,
            "minLength": 1
          },
          "maxItems": 16
        }
      },
      "additionalProperties": false,
      "required": [
        "level",
        "reasons",
        "coverage",
        "breaking_surface",
        "fanout",
        "dynamic_blind_spots"
      ]
    },
    "LanguageCoverage": {
      "description": "Per-language coverage summary.",
      "type": "object",
      "properties": {
        "language": {
          "description": "Language identity.",
          "type": "string",
          "maxLength": 64,
          "minLength": 1
        },
        "status": {
          "description": "Coverage state for this language.",
          "$ref": "#/$defs/CoverageStatus"
        },
        "tier": {
          "description": "Observed support tier.",
          "$ref": "#/$defs/AnalysisTier"
        }
      },
      "additionalProperties": false,
      "required": [
        "language",
        "tier",
        "status"
      ]
    },
    "NextAction": {
      "description": "Stable remediation hints generated from a closed set of templates.",
      "oneOf": [
        {
          "description": "Correct one named input field.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "correct_field"
            },
            "field": {
              "description": "Stable name of the invalid field.",
              "$ref": "#/$defs/DetailKey"
            }
          },
          "additionalProperties": false,
          "required": [
            "action",
            "field"
          ]
        },
        {
          "description": "Retry after the bounded delay in the envelope.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "retry"
            }
          },
          "additionalProperties": false,
          "required": [
            "action"
          ]
        },
        {
          "description": "Select a compatible contract version.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "select_supported_version"
            }
          },
          "additionalProperties": false,
          "required": [
            "action"
          ]
        },
        {
          "description": "Inspect the associated operation status.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "inspect_operation"
            }
          },
          "additionalProperties": false,
          "required": [
            "action"
          ]
        },
        {
          "description": "Rebuild the affected repository generation.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "rebuild_repository"
            }
          },
          "additionalProperties": false,
          "required": [
            "action"
          ]
        },
        {
          "description": "Collect a protected source-free support bundle.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "collect_support_bundle"
            }
          },
          "additionalProperties": false,
          "required": [
            "action"
          ]
        }
      ]
    },
    "OperationId": {
      "type": "string",
      "pattern": "^op1_[a-z2-7]{32}$"
    },
    "PublicError": {
      "description": "A stable source-redacted failure safe to serialize across public boundaries.",
      "type": "object",
      "properties": {
        "code": {
          "$ref": "#/$defs/ErrorCode"
        },
        "details": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^[a-z0-9_]+$": {
              "$ref": "#/$defs/PublicValue"
            }
          }
        },
        "generation": {
          "anyOf": [
            {
              "$ref": "#/$defs/GenerationId"
            },
            {
              "type": "null"
            }
          ]
        },
        "message": {
          "type": "string",
          "maxLength": 1024
        },
        "next_actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NextAction"
          },
          "maxItems": 8
        },
        "operation": {
          "anyOf": [
            {
              "$ref": "#/$defs/OperationId"
            },
            {
              "type": "null"
            }
          ]
        },
        "repository": {
          "anyOf": [
            {
              "$ref": "#/$defs/RepositoryId"
            },
            {
              "type": "null"
            }
          ]
        },
        "retry_after_ms": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "maximum": 86400000,
          "minimum": 0
        },
        "retryable": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "retryable",
        "details",
        "next_actions"
      ]
    },
    "PublicValue": {
      "description": "Bounded primitive values permitted in public error details.",
      "oneOf": [
        {
          "description": "A boolean property.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "boolean"
            },
            "value": {
              "type": "boolean"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "A signed integer property.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "integer"
            },
            "value": {
              "type": "integer",
              "format": "int64"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "An unsigned integer property.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "unsigned"
            },
            "value": {
              "type": "integer",
              "format": "uint64",
              "maximum": 18446744073709551615,
              "minimum": 0
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "A repository identity.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "repository"
            },
            "value": {
              "$ref": "#/$defs/RepositoryId"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "A generation identity.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "generation"
            },
            "value": {
              "$ref": "#/$defs/GenerationId"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "An operation identity.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "operation"
            },
            "value": {
              "$ref": "#/$defs/OperationId"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "A validated source-free label.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "label"
            },
            "value": {
              "$ref": "#/$defs/SafeLabel"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        }
      ]
    },
    "ReadEnvelope": {
      "description": "Common strict response envelope for generation-pinned reads.",
      "type": "object",
      "properties": {
        "coverage": {
          "description": "Relevant coverage.",
          "$ref": "#/$defs/CoverageSummary"
        },
        "data": {
          "description": "Tool-specific result.",
          "$ref": "#/$defs/ChangeImpactData"
        },
        "generation": {
          "description": "Pinned generation and freshness.",
          "$ref": "#/$defs/GenerationSummary"
        },
        "next_cursor": {
          "description": "Safe continuation cursor, when the result is pageable.",
          "$ref": "#/$defs/RequiredNullable4"
        },
        "repository": {
          "description": "Resolved repository.",
          "$ref": "#/$defs/ResolvedRepository"
        },
        "schema_version": {
          "description": "Tool response schema version.",
          "$ref": "#/$defs/SchemaVersion"
        },
        "truncated": {
          "description": "Whether any hard or requested limit stopped completion.",
          "type": "boolean"
        },
        "trust": {
          "description": "Response-level classification for all repository-derived content.",
          "$ref": "#/$defs/TrustClassification"
        },
        "usage": {
          "description": "Runtime resource accounting.",
          "$ref": "#/$defs/UsageSummary"
        },
        "warnings": {
          "description": "Source-free warnings.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/ResponseWarning"
          },
          "maxItems": 100
        }
      },
      "additionalProperties": false,
      "required": [
        "schema_version",
        "repository",
        "generation",
        "coverage",
        "data",
        "truncated",
        "next_cursor",
        "usage",
        "warnings",
        "trust"
      ]
    },
    "RepositoryId": {
      "type": "string",
      "pattern": "^repo1_[a-z2-7]{32}$"
    },
    "RequiredNullable": {
      "description": "A property that must be present and may contain JSON `null`.",
      "anyOf": [
        {
          "$ref": "#/$defs/GenerationId"
        },
        {
          "type": "null"
        }
      ]
    },
    "RequiredNullable2": {
      "description": "A property that must be present and may contain JSON `null`.",
      "anyOf": [
        {
          "$ref": "#/$defs/SymbolId"
        },
        {
          "type": "null"
        }
      ]
    },
    "RequiredNullable3": {
      "description": "A property that must be present and may contain JSON `null`.",
      "anyOf": [
        {
          "$ref": "#/$defs/FileId"
        },
        {
          "type": "null"
        }
      ]
    },
    "RequiredNullable4": {
      "description": "A property that must be present and may contain JSON `null`.",
      "anyOf": [
        {
          "$ref": "#/$defs/ContinuationCursor"
        },
        {
          "type": "null"
        }
      ]
    },
    "ResolvedChange": {
      "description": "One resolved change from the input change set.",
      "type": "object",
      "properties": {
        "classification": {
          "description": "Classification of the change.",
          "$ref": "#/$defs/ChangeClassification"
        },
        "file_id": {
          "description": "File identity for the changed span.",
          "$ref": "#/$defs/RequiredNullable3"
        },
        "kind": {
          "description": "Entity kind of the affected symbol.",
          "anyOf": [
            {
              "$ref": "#/$defs/EntityKind"
            },
            {
              "type": "null"
            }
          ]
        },
        "symbol_id": {
          "description": "Symbol identity, when the change maps to a known symbol.",
          "$ref": "#/$defs/RequiredNullable2"
        }
      },
      "additionalProperties": false,
      "required": [
        "symbol_id",
        "file_id",
        "classification"
      ]
    },
    "ResolvedRepository": {
      "description": "Resolved repository metadata.",
      "type": "object",
      "properties": {
        "display_name": {
          "description": "Rootlight-owned display label.",
          "type": "string",
          "maxLength": 256,
          "minLength": 1
        },
        "repository_id": {
          "description": "Stable repository identity.",
          "$ref": "#/$defs/RepositoryId"
        }
      },
      "additionalProperties": false,
      "required": [
        "repository_id",
        "display_name"
      ]
    },
    "ResponseWarning": {
      "description": "Source-free response warning.",
      "type": "object",
      "properties": {
        "code": {
          "description": "Stable warning code.",
          "$ref": "#/$defs/SafeLabel"
        },
        "message": {
          "description": "Rootlight-generated source-free explanation.",
          "$ref": "#/$defs/SourceFreeMessage"
        }
      },
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ]
    },
    "RiskLevel": {
      "description": "Aggregate risk level for an impact result.",
      "oneOf": [
        {
          "description": "No measurable risk.",
          "type": "string",
          "const": "none"
        },
        {
          "description": "Low risk, local changes only.",
          "type": "string",
          "const": "low"
        },
        {
          "description": "Medium risk, some cross-module effects.",
          "type": "string",
          "const": "medium"
        },
        {
          "description": "High risk, public surface or cross-service effects.",
          "type": "string",
          "const": "high"
        },
        {
          "description": "Critical risk, breaking changes with wide fanout.",
          "type": "string",
          "const": "critical"
        }
      ]
    },
    "SafeLabel": {
      "description": "A short source-free label permitted in public diagnostics.",
      "type": "string",
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "SchemaVersion": {
      "description": "Version marker carried by every first-slice response.",
      "oneOf": [
        {
          "description": "Tool contract version 1.0.",
          "type": "string",
          "const": "1.0"
        }
      ]
    },
    "ServiceImpact": {
      "description": "One cross-service or cross-repository impact.",
      "type": "object",
      "properties": {
        "confidence": {
          "description": "Confidence in the cross-boundary effect, 0 through 1000.",
          "type": "integer",
          "format": "uint16",
          "maximum": 1000,
          "minimum": 0
        },
        "kind": {
          "description": "Kind of cross-boundary effect.",
          "$ref": "#/$defs/ServiceImpactKind"
        },
        "reason": {
          "description": "Source-free reason.",
          "$ref": "#/$defs/SafeLabel"
        },
        "target": {
          "description": "Service or repository identity affected.",
          "type": "string",
          "maxLength": 512,
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "target",
        "kind",
        "confidence",
        "reason"
      ]
    },
    "ServiceImpactKind": {
      "description": "Kind of cross-service impact.",
      "oneOf": [
        {
          "description": "An HTTP route consumer is affected.",
          "type": "string",
          "const": "route_consumer"
        },
        {
          "description": "An async message consumer is affected.",
          "type": "string",
          "const": "message_consumer"
        },
        {
          "description": "A shared database schema is affected.",
          "type": "string",
          "const": "database_schema"
        },
        {
          "description": "A cross-repository symbol consumer is affected.",
          "type": "string",
          "const": "cross_repo_symbol"
        }
      ]
    },
    "SourceFreeMessage": {
      "description": "A checked Rootlight-generated message that cannot contain paths or source.",
      "type": "string",
      "maxLength": 1024,
      "minLength": 1,
      "pattern": "^[a-z0-9 -]+$"
    },
    "SymbolId": {
      "type": "string",
      "pattern": "^sym1_[a-z2-7]{39}$"
    },
    "TestCandidate": {
      "description": "One test candidate relevant to the change.",
      "type": "object",
      "properties": {
        "estimated_cost_ms": {
          "description": "Estimated execution cost in milliseconds.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "maximum": 3600000,
          "minimum": 0
        },
        "relevance": {
          "description": "Relevance score, 0 through 1000.",
          "type": "integer",
          "format": "uint16",
          "maximum": 1000,
          "minimum": 0
        },
        "test_id": {
          "description": "Test identity.",
          "type": "string",
          "maxLength": 512,
          "minLength": 1
        },
        "why": {
          "description": "Source-free rationale codes.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 128,
            "minLength": 1
          },
          "maxItems": 8,
          "minItems": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "test_id",
        "relevance",
        "why"
      ]
    },
    "TrustClassification": {
      "description": "Trust classification attached to every future source-bearing value.",
      "oneOf": [
        {
          "description": "Content originated in a repository and must be treated as data.",
          "type": "string",
          "const": "untrusted_repository_data"
        }
      ]
    },
    "UsageSummary": {
      "description": "Bounded counters returned by each read tool.",
      "type": "object",
      "properties": {
        "cache_status": {
          "description": "Cache outcome.",
          "$ref": "#/$defs/CacheStatus"
        },
        "edges": {
          "description": "Relationship edges examined.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "estimated_tokens": {
          "description": "Deterministic token estimate.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "json_bytes": {
          "description": "Encoded structured result bytes.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "rows": {
          "description": "Storage rows examined.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "source_bytes": {
          "description": "Raw source bytes returned.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "trace_id": {
          "description": "Source-free trace identity.",
          "type": "string",
          "maxLength": 128,
          "minLength": 1
        },
        "wall_time_ms": {
          "description": "Cooperative wall time in milliseconds.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "rows",
        "edges",
        "source_bytes",
        "json_bytes",
        "estimated_tokens",
        "wall_time_ms",
        "cache_status",
        "trace_id"
      ]
    }
  }
}
