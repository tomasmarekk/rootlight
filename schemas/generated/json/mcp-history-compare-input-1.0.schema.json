{
  "$id": "https://rootlight.local/schema/mcp/history.compare/input/1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HistoryCompareInput",
  "description": "Strict input for `history.compare`.",
  "type": "object",
  "properties": {
    "base": {
      "description": "Base revision or generation.",
      "$ref": "#/$defs/RevisionSelector"
    },
    "budget": {
      "description": "Response budget overrides.",
      "anyOf": [
        {
          "$ref": "#/$defs/ResponseBudget"
        }
      ]
    },
    "change_kinds": {
      "description": "Filter to specific change kinds.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/CompareChangeKind"
      },
      "maxItems": 8,
      "minItems": 1
    },
    "head": {
      "description": "Head revision or generation.",
      "$ref": "#/$defs/RevisionSelector"
    },
    "include_unchanged_context": {
      "description": "Whether to include unchanged context entities.",
      "type": "boolean"
    },
    "max_results": {
      "description": "Maximum results per page.",
      "type": "integer",
      "format": "uint16",
      "maximum": 1000,
      "minimum": 1
    },
    "profile": {
      "description": "Requested response profile.",
      "anyOf": [
        {
          "$ref": "#/$defs/ResponseProfile"
        }
      ]
    },
    "repository": {
      "description": "Repository or workspace selector.",
      "$ref": "#/$defs/RepositorySelector"
    },
    "scope": {
      "description": "Optional scope bounding.",
      "anyOf": [
        {
          "$ref": "#/$defs/CompareScope"
        }
      ]
    }
  },
  "additionalProperties": false,
  "required": [
    "repository",
    "base",
    "head"
  ],
  "$defs": {
    "CompareChangeKind": {
      "description": "Kind of change to include in comparison results.",
      "oneOf": [
        {
          "description": "Entity additions and removals.",
          "type": "string",
          "const": "entities"
        },
        {
          "description": "Signature modifications.",
          "type": "string",
          "const": "signatures"
        },
        {
          "description": "Relation additions and removals.",
          "type": "string",
          "const": "relations"
        },
        {
          "description": "Architectural boundary changes.",
          "type": "string",
          "const": "architecture"
        },
        {
          "description": "Ownership changes.",
          "type": "string",
          "const": "ownership"
        },
        {
          "description": "Test additions, removals, or modifications.",
          "type": "string",
          "const": "tests"
        },
        {
          "description": "Route or endpoint changes.",
          "type": "string",
          "const": "routes"
        },
        {
          "description": "Data schema changes.",
          "type": "string",
          "const": "data"
        }
      ]
    },
    "CompareScope": {
      "description": "Scope bounding for history comparison.",
      "type": "object",
      "properties": {
        "packages": {
          "description": "Restrict to these package identities.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 512,
            "minLength": 1
          },
          "maxItems": 128,
          "minItems": 1
        },
        "paths": {
          "description": "Restrict to these repository-relative paths.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 8192,
            "minLength": 1
          },
          "maxItems": 256,
          "minItems": 1
        },
        "symbols": {
          "description": "Restrict to these symbol identifiers.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/SymbolId"
          },
          "maxItems": 256,
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "GenerationId": {
      "type": "string",
      "pattern": "^gen1_[a-z2-7]{39}$"
    },
    "GitRevisionSelector": {
      "description": "Git revision selector.",
      "type": "object",
      "properties": {
        "git": {
          "description": "Git ref expression such as a tag, branch, or commit SHA.",
          "type": "string",
          "maxLength": 512,
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "git"
      ]
    },
    "ProvenanceLevel": {
      "description": "Provenance detail requested by a read tool.",
      "oneOf": [
        {
          "description": "Omit provenance detail beyond mandatory source identity.",
          "type": "string",
          "const": "none"
        },
        {
          "description": "Return compact provider and confidence evidence.",
          "type": "string",
          "const": "compact"
        },
        {
          "description": "Return maximum bounded provenance evidence.",
          "type": "string",
          "const": "full"
        }
      ]
    },
    "RepositoryAliasSelector": {
      "description": "Registered repository-alias selector.",
      "type": "object",
      "properties": {
        "alias": {
          "description": "Registered alias, resolved to exactly one repository.",
          "type": "string",
          "maxLength": 256,
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "alias"
      ]
    },
    "RepositoryId": {
      "type": "string",
      "pattern": "^repo1_[a-z2-7]{32}$"
    },
    "RepositoryIdSelector": {
      "description": "Stable repository-ID selector.",
      "type": "object",
      "properties": {
        "repository_id": {
          "description": "Repository identity.",
          "$ref": "#/$defs/RepositoryId"
        }
      },
      "additionalProperties": false,
      "required": [
        "repository_id"
      ]
    },
    "RepositorySelector": {
      "description": "Repository selector accepted by first-slice read tools.",
      "anyOf": [
        {
          "description": "Select by stable repository identifier.",
          "$ref": "#/$defs/RepositoryIdSelector"
        },
        {
          "description": "Select by a configured local alias.",
          "$ref": "#/$defs/RepositoryAliasSelector"
        }
      ]
    },
    "ResponseBudget": {
      "description": "Optional response limits that can only reduce server hard limits.",
      "type": "object",
      "properties": {
        "evidence_level": {
          "description": "Requested evidence detail.",
          "anyOf": [
            {
              "$ref": "#/$defs/ProvenanceLevel"
            }
          ]
        },
        "max_depth": {
          "description": "Maximum plan depth.",
          "type": "integer",
          "format": "uint8",
          "maximum": 16,
          "minimum": 1
        },
        "max_paths": {
          "description": "Maximum independently returned paths.",
          "type": "integer",
          "format": "uint16",
          "maximum": 1000,
          "minimum": 1
        },
        "max_results": {
          "description": "Maximum returned result objects.",
          "type": "integer",
          "format": "uint16",
          "maximum": 1000,
          "minimum": 1
        },
        "max_source_bytes": {
          "description": "Maximum source bytes before JSON escaping.",
          "type": "integer",
          "format": "uint32",
          "maximum": 524288,
          "minimum": 1
        },
        "max_tokens": {
          "description": "Maximum estimated output tokens.",
          "type": "integer",
          "format": "uint16",
          "maximum": 3200,
          "minimum": 100
        },
        "max_traversal_facts": {
          "description": "Maximum relationship or traversal facts examined.",
          "type": "integer",
          "format": "uint32",
          "maximum": 100000,
          "minimum": 1
        },
        "timeout_ms": {
          "description": "Cooperative request deadline in milliseconds.",
          "type": "integer",
          "format": "uint32",
          "maximum": 30000,
          "minimum": 10
        }
      },
      "additionalProperties": false
    },
    "ResponseProfile": {
      "description": "Requested response representation.",
      "oneOf": [
        {
          "description": "Smallest complete correctness-bearing response.",
          "type": "string",
          "const": "compact"
        },
        {
          "description": "More explanatory response within the same hard budgets.",
          "type": "string",
          "const": "standard"
        },
        {
          "description": "Maximum bounded provenance and evidence.",
          "type": "string",
          "const": "evidence"
        }
      ]
    },
    "RevisionSelector": {
      "description": "Selector for a revision or generation to compare.",
      "anyOf": [
        {
          "description": "Select by Git ref expression.",
          "$ref": "#/$defs/GitRevisionSelector"
        },
        {
          "description": "Select by generation identity.",
          "$ref": "#/$defs/GenerationId"
        }
      ]
    },
    "SymbolId": {
      "type": "string",
      "pattern": "^sym1_[a-z2-7]{39}$"
    }
  }
}
