{
  "$id": "https://rootlight.local/schema/mcp/architecture.overview/input/1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArchitectureOverviewInput",
  "description": "Strict input for `architecture.overview`.",
  "type": "object",
  "properties": {
    "budget": {
      "description": "Optional response limits.",
      "anyOf": [
        {
          "$ref": "#/$defs/ResponseBudget"
        }
      ]
    },
    "detail": {
      "description": "Requested detail level.",
      "anyOf": [
        {
          "$ref": "#/$defs/ArchitectureDetail"
        }
      ]
    },
    "generation": {
      "description": "Immutable generation selector.",
      "anyOf": [
        {
          "$ref": "#/$defs/GenerationSelector"
        }
      ]
    },
    "include_edges": {
      "description": "Whether to include aggregated connection edges.",
      "type": "boolean"
    },
    "max_components": {
      "description": "Maximum returned components.",
      "type": "integer",
      "format": "uint16",
      "maximum": 250,
      "minimum": 1
    },
    "min_confidence": {
      "description": "Minimum confidence for heuristic links.",
      "type": "integer",
      "format": "uint16",
      "maximum": 1000,
      "minimum": 0
    },
    "repository": {
      "description": "Owning repository.",
      "$ref": "#/$defs/RepositorySelector"
    },
    "response_profile": {
      "description": "Requested representation.",
      "anyOf": [
        {
          "$ref": "#/$defs/ResponseProfile"
        }
      ]
    },
    "scope": {
      "description": "Optional structural scope constraint.",
      "anyOf": [
        {
          "$ref": "#/$defs/ScopeSelector"
        }
      ]
    },
    "views": {
      "description": "Requested architecture views.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/ArchitectureView"
      },
      "maxItems": 8,
      "uniqueItems": true
    }
  },
  "additionalProperties": false,
  "required": [
    "repository"
  ],
  "$defs": {
    "ActiveGeneration": {
      "description": "Active-generation keyword.",
      "oneOf": [
        {
          "description": "Select the active generation.",
          "type": "string",
          "const": "active"
        }
      ]
    },
    "ArchitectureDetail": {
      "description": "Architecture detail level.",
      "oneOf": [
        {
          "description": "Minimal summary with counts.",
          "type": "string",
          "const": "summary"
        },
        {
          "description": "Standard component and connection detail.",
          "type": "string",
          "const": "standard"
        },
        {
          "description": "Maximum bounded evidence and metrics.",
          "type": "string",
          "const": "detailed"
        }
      ]
    },
    "ArchitectureView": {
      "description": "Architecture view categories.",
      "oneOf": [
        {
          "description": "Module-level decomposition.",
          "type": "string",
          "const": "modules"
        },
        {
          "description": "Package-level decomposition.",
          "type": "string",
          "const": "packages"
        },
        {
          "description": "Service boundaries.",
          "type": "string",
          "const": "services"
        },
        {
          "description": "Data stores and schemas.",
          "type": "string",
          "const": "data"
        },
        {
          "description": "Build targets and compilation units.",
          "type": "string",
          "const": "build"
        },
        {
          "description": "Ownership and authorship.",
          "type": "string",
          "const": "ownership"
        },
        {
          "description": "Community detection clusters.",
          "type": "string",
          "const": "communities"
        },
        {
          "description": "Structural hotspot ranking.",
          "type": "string",
          "const": "hotspots"
        }
      ]
    },
    "BuildTargetScope": {
      "description": "Build-target scope.",
      "type": "object",
      "properties": {
        "build_targets": {
          "description": "Distinct build-target identities.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 512,
            "minLength": 1
          },
          "maxItems": 256,
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "required": [
        "build_targets"
      ]
    },
    "GenerationId": {
      "type": "string",
      "pattern": "^gen1_[a-z2-7]{39}$"
    },
    "GenerationSelector": {
      "description": "Generation selector shared by first-slice read tools.",
      "anyOf": [
        {
          "description": "Resolve the currently active immutable generation.",
          "$ref": "#/$defs/ActiveGeneration"
        },
        {
          "description": "Pin an explicit immutable generation.",
          "$ref": "#/$defs/GenerationId"
        }
      ]
    },
    "PackageScope": {
      "description": "Package scope.",
      "type": "object",
      "properties": {
        "packages": {
          "description": "Distinct package identities.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 512,
            "minLength": 1
          },
          "maxItems": 256,
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "required": [
        "packages"
      ]
    },
    "PathScope": {
      "description": "Repository-relative path scope.",
      "type": "object",
      "properties": {
        "paths": {
          "description": "Distinct repository-relative paths.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 8192,
            "minLength": 1
          },
          "maxItems": 256,
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "required": [
        "paths"
      ]
    },
    "ProvenanceLevel": {
      "description": "Provenance detail requested by a read tool.",
      "oneOf": [
        {
          "description": "Omit provenance detail beyond mandatory source identity.",
          "type": "string",
          "const": "none"
        },
        {
          "description": "Return compact provider and confidence evidence.",
          "type": "string",
          "const": "compact"
        },
        {
          "description": "Return maximum bounded provenance evidence.",
          "type": "string",
          "const": "full"
        }
      ]
    },
    "RepositoryAliasSelector": {
      "description": "Registered repository-alias selector.",
      "type": "object",
      "properties": {
        "alias": {
          "description": "Registered alias, resolved to exactly one repository.",
          "type": "string",
          "maxLength": 256,
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "alias"
      ]
    },
    "RepositoryId": {
      "type": "string",
      "pattern": "^repo1_[a-z2-7]{32}$"
    },
    "RepositoryIdSelector": {
      "description": "Stable repository-ID selector.",
      "type": "object",
      "properties": {
        "repository_id": {
          "description": "Repository identity.",
          "$ref": "#/$defs/RepositoryId"
        }
      },
      "additionalProperties": false,
      "required": [
        "repository_id"
      ]
    },
    "RepositorySelector": {
      "description": "Repository selector accepted by first-slice read tools.",
      "anyOf": [
        {
          "description": "Select by stable repository identifier.",
          "$ref": "#/$defs/RepositoryIdSelector"
        },
        {
          "description": "Select by a configured local alias.",
          "$ref": "#/$defs/RepositoryAliasSelector"
        }
      ]
    },
    "ResponseBudget": {
      "description": "Optional response limits that can only reduce server hard limits.",
      "type": "object",
      "properties": {
        "evidence_level": {
          "description": "Requested evidence detail.",
          "anyOf": [
            {
              "$ref": "#/$defs/ProvenanceLevel"
            }
          ]
        },
        "max_depth": {
          "description": "Maximum plan depth.",
          "type": "integer",
          "format": "uint8",
          "maximum": 16,
          "minimum": 1
        },
        "max_paths": {
          "description": "Maximum independently returned paths.",
          "type": "integer",
          "format": "uint16",
          "maximum": 1000,
          "minimum": 1
        },
        "max_results": {
          "description": "Maximum returned result objects.",
          "type": "integer",
          "format": "uint16",
          "maximum": 1000,
          "minimum": 1
        },
        "max_source_bytes": {
          "description": "Maximum source bytes before JSON escaping.",
          "type": "integer",
          "format": "uint32",
          "maximum": 524288,
          "minimum": 1
        },
        "max_tokens": {
          "description": "Maximum estimated output tokens.\n\nThe schema ceiling is the largest aggregate budget any tool accepts\n(`query.batch` allows up to 16000); the server clamps each request to\nthe calling tool's own hard limit.",
          "type": "integer",
          "format": "uint16",
          "maximum": 16000,
          "minimum": 100
        },
        "max_traversal_facts": {
          "description": "Maximum relationship or traversal facts examined.",
          "type": "integer",
          "format": "uint32",
          "maximum": 100000,
          "minimum": 1
        },
        "timeout_ms": {
          "description": "Cooperative request deadline in milliseconds.",
          "type": "integer",
          "format": "uint32",
          "maximum": 30000,
          "minimum": 10
        }
      },
      "additionalProperties": false
    },
    "ResponseProfile": {
      "description": "Requested response representation.",
      "oneOf": [
        {
          "description": "Smallest complete correctness-bearing response.",
          "type": "string",
          "const": "compact"
        },
        {
          "description": "More explanatory response within the same hard budgets.",
          "type": "string",
          "const": "standard"
        },
        {
          "description": "Maximum bounded provenance and evidence.",
          "type": "string",
          "const": "evidence"
        }
      ]
    },
    "ScopeSelector": {
      "description": "Common scope selector for read tools.",
      "anyOf": [
        {
          "description": "Limit to repository-relative paths.",
          "$ref": "#/$defs/PathScope"
        },
        {
          "description": "Limit to packages.",
          "$ref": "#/$defs/PackageScope"
        },
        {
          "description": "Limit to build targets.",
          "$ref": "#/$defs/BuildTargetScope"
        },
        {
          "description": "Limit to stable symbols.",
          "$ref": "#/$defs/SymbolScope"
        }
      ]
    },
    "SymbolId": {
      "type": "string",
      "pattern": "^sym1_[a-z2-7]{39}$"
    },
    "SymbolScope": {
      "description": "Stable-symbol scope.",
      "type": "object",
      "properties": {
        "symbols": {
          "description": "Distinct symbol identities.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/SymbolId"
          },
          "maxItems": 64,
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "required": [
        "symbols"
      ]
    }
  }
}
