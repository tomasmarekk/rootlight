{
  "$id": "https://rootlight.local/schema/mcp/query.batch/output/1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ToolResponse",
  "description": "A checked success-or-error result accepted by one tool output schema.\n\nSuccessful variants preserve each tool's documented response shape.\nExpected domain failures use the same versioned [`ErrorResponse`] and\nchecked [`PublicError`] contract for every tool.",
  "type": "object",
  "anyOf": [
    {
      "description": "A tool-specific successful response.",
      "$ref": "#/$defs/ReadEnvelope"
    },
    {
      "description": "A versioned source-redacted domain error.",
      "$ref": "#/$defs/ErrorResponse"
    }
  ],
  "unevaluatedProperties": false,
  "$defs": {
    "AnalysisTier": {
      "description": "Requested or observed language support tier.",
      "oneOf": [
        {
          "description": "Compiler-quality or equivalent semantic evidence.",
          "type": "string",
          "const": "A"
        },
        {
          "description": "High-confidence partial semantic evidence.",
          "type": "string",
          "const": "B"
        },
        {
          "description": "Generic structural extraction.",
          "type": "string",
          "const": "C"
        },
        {
          "description": "Lexical-only support.",
          "type": "string",
          "const": "D"
        }
      ]
    },
    "BatchOperationResult": {
      "description": "Result of one operation inside a `query.batch` response.",
      "type": "object",
      "properties": {
        "data": {
          "description": "Tool-specific successful result data, present when status is ok."
        },
        "error": {
          "description": "Structured error, present when status is error.",
          "anyOf": [
            {
              "$ref": "#/$defs/PublicError"
            },
            {
              "type": "null"
            }
          ]
        },
        "id": {
          "description": "Operation identifier matching the request.",
          "type": "string",
          "maxLength": 32,
          "minLength": 1
        },
        "next_cursor": {
          "description": "Safe continuation cursor when the operation result is pageable.",
          "$ref": "#/$defs/RequiredNullable2"
        },
        "status": {
          "description": "Terminal status for this operation.",
          "$ref": "#/$defs/BatchOperationStatus"
        },
        "tool": {
          "description": "Tool that was executed or scheduled.",
          "$ref": "#/$defs/BatchTool"
        },
        "truncated": {
          "description": "Whether a hard or requested limit stopped this operation.",
          "type": "boolean"
        },
        "usage": {
          "description": "Runtime resource accounting for this operation.",
          "anyOf": [
            {
              "$ref": "#/$defs/UsageSummary"
            },
            {
              "type": "null"
            }
          ]
        },
        "warnings": {
          "description": "Source-free warnings local to this operation.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/ResponseWarning"
          },
          "maxItems": 32
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "tool",
        "status",
        "truncated",
        "next_cursor",
        "warnings"
      ]
    },
    "BatchOperationStatus": {
      "description": "Terminal status of one operation inside a batch.",
      "oneOf": [
        {
          "description": "The operation completed successfully.",
          "type": "string",
          "const": "ok"
        },
        {
          "description": "The operation failed at runtime with a structured error.",
          "type": "string",
          "const": "error"
        },
        {
          "description": "The operation was skipped because a declared dependency failed.",
          "type": "string",
          "const": "skipped_dependency"
        },
        {
          "description": "The operation was not scheduled because fail-fast stopped the batch.",
          "type": "string",
          "const": "not_run_fail_fast"
        },
        {
          "description": "The operation was planned in explain mode and not executed.",
          "type": "string",
          "const": "not_run"
        }
      ]
    },
    "BatchStatus": {
      "description": "Aggregate batch outcome derived from individual operation results.",
      "oneOf": [
        {
          "description": "Every operation completed successfully.",
          "type": "string",
          "const": "ok"
        },
        {
          "description": "At least one operation succeeded and at least one failed or was skipped.",
          "type": "string",
          "const": "partial"
        },
        {
          "description": "No operation produced a successful result.",
          "type": "string",
          "const": "error"
        },
        {
          "description": "The batch plan was validated in explain mode without executing operations.",
          "type": "string",
          "const": "planned"
        }
      ]
    },
    "BatchTool": {
      "description": "Closed allowlist of tools composable inside a public `query.batch`.\n\nSerialized with dotted public tool names. Mutation tools, polling, nested\nbatches, `history.compare`, `query.advanced`, cross-generation operations,\nand unbounded fanout are forbidden.",
      "oneOf": [
        {
          "description": "Bounded structural or lexical code search.",
          "type": "string",
          "const": "code.locate"
        },
        {
          "description": "Semantic evidence for stable symbol identifiers.",
          "type": "string",
          "const": "symbol.explain"
        },
        {
          "description": "Typed relationship traversal for one or more symbols.",
          "type": "string",
          "const": "symbol.relationships"
        },
        {
          "description": "Cross-service or cross-module flow tracing.",
          "type": "string",
          "const": "flow.trace"
        },
        {
          "description": "Bounded change-impact analysis.",
          "type": "string",
          "const": "change.impact"
        },
        {
          "description": "Test selection for given symbols or paths.",
          "type": "string",
          "const": "tests.select"
        },
        {
          "description": "High-level architecture overview.",
          "type": "string",
          "const": "architecture.overview"
        },
        {
          "description": "Dependency-cycle detection.",
          "type": "string",
          "const": "architecture.cycles"
        },
        {
          "description": "Dead-code detection.",
          "type": "string",
          "const": "code.dead"
        },
        {
          "description": "Ordered change planning.",
          "type": "string",
          "const": "plan.change"
        },
        {
          "description": "Context pack assembly.",
          "type": "string",
          "const": "context.pack"
        },
        {
          "description": "Generation-pinned source range reads.",
          "type": "string",
          "const": "source.read"
        }
      ]
    },
    "CacheStatus": {
      "description": "Cache classification for usage reporting.",
      "oneOf": [
        {
          "description": "No cache entry was used.",
          "type": "string",
          "const": "miss"
        },
        {
          "description": "A verified generation-bound cache entry was used.",
          "type": "string",
          "const": "hit"
        },
        {
          "description": "The operator does not use a cache.",
          "type": "string",
          "const": "not_applicable"
        }
      ]
    },
    "ContinuationCursor": {
      "description": "A bounded opaque continuation cursor.",
      "type": "string",
      "maxLength": 4096,
      "minLength": 1
    },
    "CoverageStatus": {
      "description": "Completeness of a bounded fact or result set.",
      "oneOf": [
        {
          "description": "The declared domain was completely analyzed.",
          "type": "string",
          "const": "complete"
        },
        {
          "description": "A documented bound truncated the domain.",
          "type": "string",
          "const": "bounded"
        },
        {
          "description": "A representative sample was analyzed.",
          "type": "string",
          "const": "sampled"
        },
        {
          "description": "Completeness could not be established.",
          "type": "string",
          "const": "unknown"
        }
      ]
    },
    "CoverageSummary": {
      "description": "Coverage metadata relevant to one query.",
      "type": "object",
      "properties": {
        "languages": {
          "description": "Deterministically ordered language coverage.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/LanguageCoverage"
          },
          "maxItems": 64
        },
        "skipped_inputs": {
          "description": "Inputs skipped by policy, limits, or capability.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "status": {
          "description": "Aggregate query-domain coverage.",
          "$ref": "#/$defs/CoverageStatus"
        }
      },
      "additionalProperties": false,
      "required": [
        "status",
        "languages",
        "skipped_inputs"
      ]
    },
    "DetailKey": {
      "description": "A validated key for a bounded public error detail.",
      "type": "string",
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^[a-z0-9_]+$"
    },
    "ErrorCode": {
      "description": "Stable public error families shared by all Rootlight boundaries.",
      "oneOf": [
        {
          "description": "The caller supplied an invalid value.",
          "type": "string",
          "const": "INVALID_ARGUMENT"
        },
        {
          "description": "The requested entity does not exist.",
          "type": "string",
          "const": "NOT_FOUND"
        },
        {
          "description": "The request conflicts with current state.",
          "type": "string",
          "const": "CONFLICT"
        },
        {
          "description": "The selected generation is no longer valid for this operation.",
          "type": "string",
          "const": "STALE_GENERATION"
        },
        {
          "description": "The requested capability is unavailable.",
          "type": "string",
          "const": "UNSUPPORTED_CAPABILITY"
        },
        {
          "description": "The result is incomplete for the requested coverage.",
          "type": "string",
          "const": "INCOMPLETE_COVERAGE"
        },
        {
          "description": "The operation exceeded an explicit work budget.",
          "type": "string",
          "const": "BUDGET_EXCEEDED"
        },
        {
          "description": "A bounded resource is exhausted.",
          "type": "string",
          "const": "RESOURCE_EXHAUSTED"
        },
        {
          "description": "The operation was cancelled before completion.",
          "type": "string",
          "const": "CANCELLED"
        },
        {
          "description": "An isolated adapter failed.",
          "type": "string",
          "const": "ADAPTER_FAILED"
        },
        {
          "description": "An index failed integrity checks.",
          "type": "string",
          "const": "INDEX_CORRUPT"
        },
        {
          "description": "Stored data requires a supported migration.",
          "type": "string",
          "const": "MIGRATION_REQUIRED"
        },
        {
          "description": "Policy denied the requested operation.",
          "type": "string",
          "const": "PERMISSION_DENIED"
        },
        {
          "description": "A protocol or contract version is incompatible.",
          "type": "string",
          "const": "PROTOCOL_MISMATCH"
        },
        {
          "description": "A conflicting operation temporarily owns the resource.",
          "type": "string",
          "const": "BUSY"
        },
        {
          "description": "An internal failure cannot be safely disclosed.",
          "type": "string",
          "const": "INTERNAL"
        },
        {
          "description": "A pagination cursor is invalid, expired, forged, or context-mismatched.",
          "type": "string",
          "const": "INVALID_CURSOR"
        },
        {
          "description": "A supplied value has the wrong type for its target field.",
          "type": "string",
          "const": "TYPE_MISMATCH"
        },
        {
          "description": "The request exceeded a cost limit before execution.",
          "type": "string",
          "const": "COST_LIMIT"
        },
        {
          "description": "The query uses an operator outside the documented allowlist.",
          "type": "string",
          "const": "OPERATOR_FORBIDDEN"
        },
        {
          "description": "A batch binding reference is malformed or unresolved.",
          "type": "string",
          "const": "BINDING_INVALID"
        },
        {
          "description": "A batch binding produced a value of the wrong type for its target.",
          "type": "string",
          "const": "BINDING_TYPE_MISMATCH"
        }
      ]
    },
    "ErrorResponse": {
      "description": "Strict common error response for MCP contract failures.",
      "type": "object",
      "properties": {
        "error": {
          "description": "Stable public error envelope.",
          "$ref": "#/$defs/PublicError"
        },
        "schema_version": {
          "description": "Tool error schema version.",
          "$ref": "#/$defs/SchemaVersion"
        }
      },
      "additionalProperties": false,
      "required": [
        "schema_version",
        "error"
      ]
    },
    "Freshness": {
      "description": "Freshness of one immutable generation.",
      "oneOf": [
        {
          "description": "Matches the currently observed repository snapshot.",
          "type": "string",
          "const": "current"
        },
        {
          "description": "Queryable but a newer generation exists.",
          "type": "string",
          "const": "superseded"
        },
        {
          "description": "Queryable with a known stale source snapshot.",
          "type": "string",
          "const": "stale"
        }
      ]
    },
    "GenerationId": {
      "type": "string",
      "pattern": "^gen1_[a-z2-7]{39}$"
    },
    "GenerationSummary": {
      "description": "Generation metadata carried by each read response.",
      "type": "object",
      "properties": {
        "generation_id": {
          "description": "Pinned generation.",
          "$ref": "#/$defs/GenerationId"
        },
        "parent_generation": {
          "description": "Parent generation, if any.",
          "$ref": "#/$defs/RequiredNullable"
        },
        "semantic_freshness": {
          "description": "Semantic freshness.",
          "$ref": "#/$defs/Freshness"
        },
        "structural_freshness": {
          "description": "Structural freshness.",
          "$ref": "#/$defs/Freshness"
        }
      },
      "additionalProperties": false,
      "required": [
        "generation_id",
        "parent_generation",
        "structural_freshness",
        "semantic_freshness"
      ]
    },
    "LanguageCoverage": {
      "description": "Per-language coverage summary.",
      "type": "object",
      "properties": {
        "language": {
          "description": "Language identity.",
          "type": "string",
          "maxLength": 64,
          "minLength": 1
        },
        "status": {
          "description": "Coverage state for this language.",
          "$ref": "#/$defs/CoverageStatus"
        },
        "tier": {
          "description": "Observed support tier.",
          "$ref": "#/$defs/AnalysisTier"
        }
      },
      "additionalProperties": false,
      "required": [
        "language",
        "tier",
        "status"
      ]
    },
    "NextAction": {
      "description": "Stable remediation hints generated from a closed set of templates.",
      "oneOf": [
        {
          "description": "Correct one named input field.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "correct_field"
            },
            "field": {
              "description": "Stable name of the invalid field.",
              "$ref": "#/$defs/DetailKey"
            }
          },
          "additionalProperties": false,
          "required": [
            "action",
            "field"
          ]
        },
        {
          "description": "Retry after the bounded delay in the envelope.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "retry"
            }
          },
          "additionalProperties": false,
          "required": [
            "action"
          ]
        },
        {
          "description": "Select a compatible contract version.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "select_supported_version"
            }
          },
          "additionalProperties": false,
          "required": [
            "action"
          ]
        },
        {
          "description": "Inspect the associated operation status.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "inspect_operation"
            }
          },
          "additionalProperties": false,
          "required": [
            "action"
          ]
        },
        {
          "description": "Rebuild the affected repository generation.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "rebuild_repository"
            }
          },
          "additionalProperties": false,
          "required": [
            "action"
          ]
        },
        {
          "description": "Collect a protected source-free support bundle.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "collect_support_bundle"
            }
          },
          "additionalProperties": false,
          "required": [
            "action"
          ]
        },
        {
          "description": "Restart the enumeration or query from the beginning after an invalid\ncontinuation cursor.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "restart_enumeration"
            }
          },
          "additionalProperties": false,
          "required": [
            "action"
          ]
        }
      ]
    },
    "OperationId": {
      "type": "string",
      "pattern": "^op1_[a-z2-7]{32}$"
    },
    "PlanExplanation": {
      "description": "Explainable cost and plan for an advanced query execution.",
      "type": "object",
      "properties": {
        "applied_limits": {
          "description": "Applied limit descriptions.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 256,
            "minLength": 1
          },
          "maxItems": 16
        },
        "estimated_cost": {
          "description": "Estimated total cost units for the query plan.",
          "type": "integer",
          "format": "uint64",
          "maximum": 10000000,
          "minimum": 0
        },
        "fingerprint": {
          "description": "Stable physical-plan fingerprint bound to the plan and pinned generation.",
          "type": "string",
          "maxLength": 128
        },
        "operators": {
          "description": "Ordered operator names in the physical plan.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 128,
            "minLength": 1
          },
          "maxItems": 64
        },
        "planner_version": {
          "description": "Planner version that produced the plan; part of the fingerprint input.",
          "type": "integer",
          "format": "uint32",
          "maximum": 1000,
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "estimated_cost",
        "operators",
        "applied_limits",
        "planner_version",
        "fingerprint"
      ]
    },
    "PublicError": {
      "description": "A stable source-redacted failure safe to serialize across public boundaries.",
      "type": "object",
      "properties": {
        "code": {
          "$ref": "#/$defs/ErrorCode"
        },
        "details": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^[a-z0-9_]+$": {
              "$ref": "#/$defs/PublicValue"
            }
          }
        },
        "generation": {
          "anyOf": [
            {
              "$ref": "#/$defs/GenerationId"
            },
            {
              "type": "null"
            }
          ]
        },
        "message": {
          "type": "string",
          "maxLength": 1024
        },
        "next_actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NextAction"
          },
          "maxItems": 8
        },
        "operation": {
          "anyOf": [
            {
              "$ref": "#/$defs/OperationId"
            },
            {
              "type": "null"
            }
          ]
        },
        "repository": {
          "anyOf": [
            {
              "$ref": "#/$defs/RepositoryId"
            },
            {
              "type": "null"
            }
          ]
        },
        "retry_after_ms": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "maximum": 86400000,
          "minimum": 0
        },
        "retryable": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "retryable",
        "details",
        "next_actions"
      ]
    },
    "PublicValue": {
      "description": "Bounded primitive values permitted in public error details.",
      "oneOf": [
        {
          "description": "A boolean property.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "boolean"
            },
            "value": {
              "type": "boolean"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "A signed integer property.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "integer"
            },
            "value": {
              "type": "integer",
              "format": "int64"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "An unsigned integer property.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "unsigned"
            },
            "value": {
              "type": "integer",
              "format": "uint64",
              "maximum": 18446744073709551615,
              "minimum": 0
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "A repository identity.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "repository"
            },
            "value": {
              "$ref": "#/$defs/RepositoryId"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "A generation identity.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "generation"
            },
            "value": {
              "$ref": "#/$defs/GenerationId"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "An operation identity.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "operation"
            },
            "value": {
              "$ref": "#/$defs/OperationId"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "A validated source-free label.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "label"
            },
            "value": {
              "$ref": "#/$defs/SafeLabel"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        }
      ]
    },
    "QueryBatchData": {
      "description": "`query.batch` result data.",
      "type": "object",
      "properties": {
        "batch_status": {
          "description": "Aggregate outcome derived from all operation results.",
          "$ref": "#/$defs/BatchStatus"
        },
        "explanation": {
          "description": "Bounded source-free plan present when explain was requested.",
          "anyOf": [
            {
              "$ref": "#/$defs/PlanExplanation"
            },
            {
              "type": "null"
            }
          ]
        },
        "generation_id": {
          "description": "The single generation pinned for every operation in the batch.",
          "$ref": "#/$defs/GenerationId"
        },
        "operation_results": {
          "description": "One result per requested operation in original request order.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/BatchOperationResult"
          },
          "maxItems": 16,
          "minItems": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "batch_status",
        "generation_id",
        "operation_results"
      ]
    },
    "ReadEnvelope": {
      "description": "Common strict response envelope for generation-pinned reads.",
      "type": "object",
      "properties": {
        "coverage": {
          "description": "Relevant coverage.",
          "$ref": "#/$defs/CoverageSummary"
        },
        "data": {
          "description": "Tool-specific result.",
          "$ref": "#/$defs/QueryBatchData"
        },
        "generation": {
          "description": "Pinned generation and freshness.",
          "$ref": "#/$defs/GenerationSummary"
        },
        "next_cursor": {
          "description": "Safe continuation cursor, when the result is pageable.",
          "$ref": "#/$defs/RequiredNullable2"
        },
        "repository": {
          "description": "Resolved repository.",
          "$ref": "#/$defs/ResolvedRepository"
        },
        "schema_version": {
          "description": "Tool response schema version.",
          "$ref": "#/$defs/SchemaVersion"
        },
        "truncated": {
          "description": "Whether any hard or requested limit stopped completion.",
          "type": "boolean"
        },
        "trust": {
          "description": "Response-level classification for all repository-derived content.",
          "$ref": "#/$defs/TrustClassification"
        },
        "usage": {
          "description": "Runtime resource accounting.",
          "$ref": "#/$defs/UsageSummary"
        },
        "warnings": {
          "description": "Source-free warnings.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/ResponseWarning"
          },
          "maxItems": 100
        }
      },
      "additionalProperties": false,
      "required": [
        "schema_version",
        "repository",
        "generation",
        "coverage",
        "data",
        "truncated",
        "next_cursor",
        "usage",
        "warnings",
        "trust"
      ]
    },
    "RepositoryId": {
      "type": "string",
      "pattern": "^repo1_[a-z2-7]{32}$"
    },
    "RequiredNullable": {
      "description": "A property that must be present and may contain JSON `null`.",
      "anyOf": [
        {
          "$ref": "#/$defs/GenerationId"
        },
        {
          "type": "null"
        }
      ]
    },
    "RequiredNullable2": {
      "description": "A property that must be present and may contain JSON `null`.",
      "anyOf": [
        {
          "$ref": "#/$defs/ContinuationCursor"
        },
        {
          "type": "null"
        }
      ]
    },
    "ResolvedRepository": {
      "description": "Resolved repository metadata.",
      "type": "object",
      "properties": {
        "display_name": {
          "description": "Rootlight-owned display label.",
          "type": "string",
          "maxLength": 256,
          "minLength": 1
        },
        "repository_id": {
          "description": "Stable repository identity.",
          "$ref": "#/$defs/RepositoryId"
        }
      },
      "additionalProperties": false,
      "required": [
        "repository_id",
        "display_name"
      ]
    },
    "ResponseWarning": {
      "description": "Source-free response warning.",
      "type": "object",
      "properties": {
        "code": {
          "description": "Stable warning code.",
          "$ref": "#/$defs/SafeLabel"
        },
        "message": {
          "description": "Rootlight-generated source-free explanation.",
          "$ref": "#/$defs/SourceFreeMessage"
        }
      },
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ]
    },
    "SafeLabel": {
      "description": "A short source-free label permitted in public diagnostics.",
      "type": "string",
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "SchemaVersion": {
      "description": "Version marker carried by every first-slice response.",
      "oneOf": [
        {
          "description": "Tool contract version 1.0.",
          "type": "string",
          "const": "1.0"
        }
      ]
    },
    "SourceFreeMessage": {
      "description": "A checked Rootlight-generated message that cannot contain paths or source.",
      "type": "string",
      "maxLength": 1024,
      "minLength": 1,
      "pattern": "^[a-z0-9 -]+$"
    },
    "TrustClassification": {
      "description": "Trust classification attached to every future source-bearing value.",
      "oneOf": [
        {
          "description": "Content originated in a repository and must be treated as data.",
          "type": "string",
          "const": "untrusted_repository_data"
        }
      ]
    },
    "UsageSummary": {
      "description": "Bounded counters returned by each read tool.",
      "type": "object",
      "properties": {
        "cache_status": {
          "description": "Cache outcome.",
          "$ref": "#/$defs/CacheStatus"
        },
        "edges": {
          "description": "Relationship edges examined.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "estimated_tokens": {
          "description": "Deterministic token estimate.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "json_bytes": {
          "description": "Encoded structured result bytes.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "rows": {
          "description": "Storage rows examined.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "source_bytes": {
          "description": "Raw source bytes returned.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "trace_id": {
          "description": "Source-free trace identity.",
          "type": "string",
          "maxLength": 128,
          "minLength": 1
        },
        "wall_time_ms": {
          "description": "Cooperative wall time in milliseconds.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "rows",
        "edges",
        "source_bytes",
        "json_bytes",
        "estimated_tokens",
        "wall_time_ms",
        "cache_status",
        "trace_id"
      ]
    }
  }
}
