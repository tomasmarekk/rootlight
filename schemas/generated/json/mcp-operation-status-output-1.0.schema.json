{
  "$id": "https://rootlight.local/schema/mcp/operation.status/output/1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ToolResponse",
  "description": "A checked success-or-error result accepted by one tool output schema.\n\nSuccessful variants preserve each tool's documented response shape.\nExpected domain failures use the same versioned [`ErrorResponse`] and\nchecked [`PublicError`] contract for every tool.",
  "type": "object",
  "anyOf": [
    {
      "description": "A tool-specific successful response.",
      "$ref": "#/$defs/OperationStatusSuccess"
    },
    {
      "description": "A versioned source-redacted domain error.",
      "$ref": "#/$defs/ErrorResponse"
    }
  ],
  "unevaluatedProperties": false,
  "$defs": {
    "DetailKey": {
      "description": "A validated key for a bounded public error detail.",
      "type": "string",
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^[a-z0-9_]+$"
    },
    "ErrorCode": {
      "description": "Stable public error families shared by all Rootlight boundaries.",
      "oneOf": [
        {
          "description": "The caller supplied an invalid value.",
          "type": "string",
          "const": "INVALID_ARGUMENT"
        },
        {
          "description": "The requested entity does not exist.",
          "type": "string",
          "const": "NOT_FOUND"
        },
        {
          "description": "The request conflicts with current state.",
          "type": "string",
          "const": "CONFLICT"
        },
        {
          "description": "The selected generation is no longer valid for this operation.",
          "type": "string",
          "const": "STALE_GENERATION"
        },
        {
          "description": "The requested capability is unavailable.",
          "type": "string",
          "const": "UNSUPPORTED_CAPABILITY"
        },
        {
          "description": "The result is incomplete for the requested coverage.",
          "type": "string",
          "const": "INCOMPLETE_COVERAGE"
        },
        {
          "description": "The operation exceeded an explicit work budget.",
          "type": "string",
          "const": "BUDGET_EXCEEDED"
        },
        {
          "description": "A bounded resource is exhausted.",
          "type": "string",
          "const": "RESOURCE_EXHAUSTED"
        },
        {
          "description": "The operation was cancelled before completion.",
          "type": "string",
          "const": "CANCELLED"
        },
        {
          "description": "An isolated adapter failed.",
          "type": "string",
          "const": "ADAPTER_FAILED"
        },
        {
          "description": "An index failed integrity checks.",
          "type": "string",
          "const": "INDEX_CORRUPT"
        },
        {
          "description": "Stored data requires a supported migration.",
          "type": "string",
          "const": "MIGRATION_REQUIRED"
        },
        {
          "description": "Policy denied the requested operation.",
          "type": "string",
          "const": "PERMISSION_DENIED"
        },
        {
          "description": "A protocol or contract version is incompatible.",
          "type": "string",
          "const": "PROTOCOL_MISMATCH"
        },
        {
          "description": "A conflicting operation temporarily owns the resource.",
          "type": "string",
          "const": "BUSY"
        },
        {
          "description": "An internal failure cannot be safely disclosed.",
          "type": "string",
          "const": "INTERNAL"
        }
      ]
    },
    "ErrorResponse": {
      "description": "Strict common error response for MCP contract failures.",
      "type": "object",
      "properties": {
        "error": {
          "description": "Stable public error envelope.",
          "$ref": "#/$defs/PublicError"
        },
        "schema_version": {
          "description": "Tool error schema version.",
          "$ref": "#/$defs/SchemaVersion"
        }
      },
      "additionalProperties": false,
      "required": [
        "schema_version",
        "error"
      ]
    },
    "GenerationId": {
      "type": "string",
      "pattern": "^gen1_[a-z2-7]{39}$"
    },
    "NextAction": {
      "description": "Stable remediation hints generated from a closed set of templates.",
      "oneOf": [
        {
          "description": "Correct one named input field.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "correct_field"
            },
            "field": {
              "description": "Stable name of the invalid field.",
              "$ref": "#/$defs/DetailKey"
            }
          },
          "additionalProperties": false,
          "required": [
            "action",
            "field"
          ]
        },
        {
          "description": "Retry after the bounded delay in the envelope.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "retry"
            }
          },
          "additionalProperties": false,
          "required": [
            "action"
          ]
        },
        {
          "description": "Select a compatible contract version.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "select_supported_version"
            }
          },
          "additionalProperties": false,
          "required": [
            "action"
          ]
        },
        {
          "description": "Inspect the associated operation status.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "inspect_operation"
            }
          },
          "additionalProperties": false,
          "required": [
            "action"
          ]
        },
        {
          "description": "Rebuild the affected repository generation.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "rebuild_repository"
            }
          },
          "additionalProperties": false,
          "required": [
            "action"
          ]
        },
        {
          "description": "Collect a protected source-free support bundle.",
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "const": "collect_support_bundle"
            }
          },
          "additionalProperties": false,
          "required": [
            "action"
          ]
        }
      ]
    },
    "OperationDetail": {
      "description": "One operation journal view.",
      "type": "object",
      "properties": {
        "kind": {
          "description": "Operation kind.",
          "type": "string",
          "maxLength": 128,
          "minLength": 1
        },
        "progress": {
          "description": "Bounded progress counters.",
          "$ref": "#/$defs/OperationProgress"
        },
        "resources": {
          "description": "Bounded resource summary.",
          "$ref": "#/$defs/OperationResources"
        },
        "revision": {
          "description": "Monotonic journal revision.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "stage": {
          "description": "Current source-free stage name.",
          "type": "string",
          "maxLength": 128,
          "minLength": 1
        },
        "started_at": {
          "description": "RFC 3339 UTC creation time.",
          "type": "string",
          "maxLength": 35,
          "minLength": 20
        },
        "state": {
          "description": "Durable state.",
          "$ref": "#/$defs/OperationState"
        }
      },
      "additionalProperties": false,
      "required": [
        "kind",
        "state",
        "stage",
        "progress",
        "revision",
        "started_at",
        "resources"
      ]
    },
    "OperationId": {
      "type": "string",
      "pattern": "^op1_[a-z2-7]{32}$"
    },
    "OperationProgress": {
      "description": "Progress units reported by an operation.",
      "type": "object",
      "properties": {
        "completed_units": {
          "description": "Completed units.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "total_units": {
          "description": "Known total units, when measurable.",
          "$ref": "#/$defs/RequiredNullable"
        }
      },
      "additionalProperties": false,
      "required": [
        "completed_units",
        "total_units"
      ]
    },
    "OperationResources": {
      "description": "Bounded resource counters for one operation.",
      "type": "object",
      "properties": {
        "files_examined": {
          "description": "Files examined so far.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "peak_rss_bytes": {
          "description": "Peak resident bytes observed so far.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        },
        "written_bytes": {
          "description": "Durable bytes written so far.",
          "type": "integer",
          "format": "uint64",
          "maximum": 18446744073709551615,
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "peak_rss_bytes",
        "written_bytes",
        "files_examined"
      ]
    },
    "OperationState": {
      "description": "Durable operation state.",
      "oneOf": [
        {
          "description": "Accepted but not started.",
          "type": "string",
          "const": "queued"
        },
        {
          "description": "Actively running.",
          "type": "string",
          "const": "running"
        },
        {
          "description": "Published an immutable generation.",
          "type": "string",
          "const": "published"
        },
        {
          "description": "Failed without publishing partial state.",
          "type": "string",
          "const": "failed"
        },
        {
          "description": "Cancelled without publishing partial state.",
          "type": "string",
          "const": "cancelled"
        },
        {
          "description": "Waiting for explicit build or environment context.",
          "type": "string",
          "const": "waiting_for_context"
        }
      ]
    },
    "OperationStatusData": {
      "description": "`operation.status` result data.",
      "type": "object",
      "properties": {
        "error": {
          "description": "Terminal public error, if any.",
          "$ref": "#/$defs/RequiredNullable3"
        },
        "operation": {
          "description": "Current operation view.",
          "$ref": "#/$defs/OperationDetail"
        },
        "published_generation": {
          "description": "Generation published by the operation, if any.",
          "$ref": "#/$defs/RequiredNullable2"
        },
        "retry_after_ms": {
          "description": "Recommended delay before polling again.",
          "$ref": "#/$defs/RequiredNullable4"
        }
      },
      "additionalProperties": false,
      "required": [
        "operation",
        "published_generation",
        "error",
        "retry_after_ms"
      ]
    },
    "OperationStatusSuccess": {
      "description": "Strict output for `operation.status`.",
      "type": "object",
      "properties": {
        "data": {
          "description": "Operation result.",
          "$ref": "#/$defs/OperationStatusData"
        },
        "schema_version": {
          "description": "Tool response schema version.",
          "$ref": "#/$defs/SchemaVersion"
        }
      },
      "additionalProperties": false,
      "required": [
        "schema_version",
        "data"
      ]
    },
    "PublicError": {
      "description": "A stable source-redacted failure safe to serialize across public boundaries.",
      "type": "object",
      "properties": {
        "code": {
          "$ref": "#/$defs/ErrorCode"
        },
        "details": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^[a-z0-9_]+$": {
              "$ref": "#/$defs/PublicValue"
            }
          }
        },
        "generation": {
          "anyOf": [
            {
              "$ref": "#/$defs/GenerationId"
            },
            {
              "type": "null"
            }
          ]
        },
        "message": {
          "type": "string",
          "maxLength": 1024
        },
        "next_actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NextAction"
          },
          "maxItems": 8
        },
        "operation": {
          "anyOf": [
            {
              "$ref": "#/$defs/OperationId"
            },
            {
              "type": "null"
            }
          ]
        },
        "repository": {
          "anyOf": [
            {
              "$ref": "#/$defs/RepositoryId"
            },
            {
              "type": "null"
            }
          ]
        },
        "retry_after_ms": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "maximum": 86400000,
          "minimum": 0
        },
        "retryable": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "retryable",
        "details",
        "next_actions"
      ]
    },
    "PublicValue": {
      "description": "Bounded primitive values permitted in public error details.",
      "oneOf": [
        {
          "description": "A boolean property.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "boolean"
            },
            "value": {
              "type": "boolean"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "A signed integer property.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "integer"
            },
            "value": {
              "type": "integer",
              "format": "int64"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "An unsigned integer property.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "unsigned"
            },
            "value": {
              "type": "integer",
              "format": "uint64",
              "maximum": 18446744073709551615,
              "minimum": 0
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "A repository identity.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "repository"
            },
            "value": {
              "$ref": "#/$defs/RepositoryId"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "A generation identity.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "generation"
            },
            "value": {
              "$ref": "#/$defs/GenerationId"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "An operation identity.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "operation"
            },
            "value": {
              "$ref": "#/$defs/OperationId"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        },
        {
          "description": "A validated source-free label.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "label"
            },
            "value": {
              "$ref": "#/$defs/SafeLabel"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ]
        }
      ]
    },
    "RepositoryId": {
      "type": "string",
      "pattern": "^repo1_[a-z2-7]{32}$"
    },
    "RequiredNullable": {
      "description": "A property that must be present and may contain JSON `null`.",
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "maximum": 18446744073709551615,
      "minimum": 0
    },
    "RequiredNullable2": {
      "description": "A property that must be present and may contain JSON `null`.",
      "anyOf": [
        {
          "$ref": "#/$defs/GenerationId"
        },
        {
          "type": "null"
        }
      ]
    },
    "RequiredNullable3": {
      "description": "A property that must be present and may contain JSON `null`.",
      "anyOf": [
        {
          "$ref": "#/$defs/PublicError"
        },
        {
          "type": "null"
        }
      ]
    },
    "RequiredNullable4": {
      "description": "A property that must be present and may contain JSON `null`.",
      "type": [
        "integer",
        "null"
      ],
      "format": "uint32",
      "minimum": 0
    },
    "SafeLabel": {
      "description": "A short source-free label permitted in public diagnostics.",
      "type": "string",
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "SchemaVersion": {
      "description": "Version marker carried by every first-slice response.",
      "oneOf": [
        {
          "description": "Tool contract version 1.0.",
          "type": "string",
          "const": "1.0"
        }
      ]
    }
  }
}
