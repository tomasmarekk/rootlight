{
  "$id": "https://rootlight.local/schema/mcp/context.pack/input/1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ContextPackInput",
  "description": "Strict input for `context.pack`.",
  "type": "object",
  "properties": {
    "continuation": {
      "description": "Progressive detail handle from a prior pack response.",
      "anyOf": [
        {
          "$ref": "#/$defs/ContinuationCursor"
        }
      ]
    },
    "diversity": {
      "description": "Diversity bias applied under a tight budget.",
      "anyOf": [
        {
          "$ref": "#/$defs/Diversity"
        }
      ]
    },
    "generation": {
      "description": "Immutable generation to pin evidence resolution; defaults to active.",
      "anyOf": [
        {
          "$ref": "#/$defs/GenerationSelector"
        }
      ]
    },
    "min_confidence": {
      "description": "Minimum evidence confidence, integer 0 through 1000; defaults to 700.",
      "type": "integer",
      "format": "uint16",
      "maximum": 1000,
      "minimum": 0
    },
    "repository": {
      "description": "Repository or workspace selector.",
      "$ref": "#/$defs/RepositorySelector"
    },
    "sections": {
      "description": "Evidence sections to assemble.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/ContextSection"
      },
      "maxItems": 9
    },
    "seeds": {
      "description": "Starting points that anchor the evidence pack.",
      "$ref": "#/$defs/ContextSeedSelector"
    },
    "source_policy": {
      "description": "How much source detail the pack may include.",
      "anyOf": [
        {
          "$ref": "#/$defs/SourcePolicy"
        }
      ]
    },
    "task": {
      "description": "Specific coding, review, debugging, or refactoring objective.",
      "type": "string",
      "maxLength": 4096,
      "minLength": 1
    },
    "token_budget": {
      "description": "Maximum estimated output tokens (minimum 500, hard maximum 20000).",
      "type": "integer",
      "format": "uint16",
      "maximum": 20000,
      "minimum": 500
    }
  },
  "additionalProperties": false,
  "required": [
    "repository",
    "task",
    "seeds",
    "token_budget"
  ],
  "$defs": {
    "ActiveGeneration": {
      "description": "Active-generation keyword.",
      "oneOf": [
        {
          "description": "Select the active generation.",
          "type": "string",
          "const": "active"
        }
      ]
    },
    "ContextSection": {
      "description": "Evidence sections a pack may assemble.",
      "oneOf": [
        {
          "description": "Module, layer, or service boundaries.",
          "type": "string",
          "const": "architecture"
        },
        {
          "description": "Primary symbol definitions.",
          "type": "string",
          "const": "definitions"
        },
        {
          "description": "Caller evidence.",
          "type": "string",
          "const": "callers"
        },
        {
          "description": "Callee evidence.",
          "type": "string",
          "const": "callees"
        },
        {
          "description": "Type and signature evidence.",
          "type": "string",
          "const": "types"
        },
        {
          "description": "Covering tests.",
          "type": "string",
          "const": "tests"
        },
        {
          "description": "Recent change history.",
          "type": "string",
          "const": "history"
        },
        {
          "description": "Source snippets.",
          "type": "string",
          "const": "source"
        },
        {
          "description": "Risk signals.",
          "type": "string",
          "const": "risks"
        }
      ]
    },
    "ContextSeedSelector": {
      "description": "Seed selector that anchors a context pack to one or more starting points.\n\nAt least one seed kind must be supplied; the router rejects an empty\nselector. Handles refer to prior bounded results and stay opaque.",
      "type": "object",
      "properties": {
        "change": {
          "description": "Revision or change-set descriptor.",
          "type": "string",
          "maxLength": 256,
          "minLength": 1
        },
        "located": {
          "description": "Opaque handle to a prior located result set.",
          "anyOf": [
            {
              "$ref": "#/$defs/ContinuationCursor"
            }
          ]
        },
        "paths": {
          "description": "Repository-relative paths to anchor the pack.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 4096,
            "minLength": 1
          },
          "maxItems": 32
        },
        "plan": {
          "description": "Opaque handle to a prior change plan.",
          "type": "string",
          "maxLength": 256,
          "minLength": 1
        },
        "routes": {
          "description": "Service or route names to anchor the pack.",
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 4096,
            "minLength": 1
          },
          "maxItems": 32
        },
        "symbols": {
          "description": "Stable symbol identifiers to anchor the pack.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/SymbolId"
          },
          "maxItems": 32
        },
        "tests": {
          "description": "Stable test symbol identifiers to anchor the pack.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/SymbolId"
          },
          "maxItems": 32
        }
      },
      "additionalProperties": false
    },
    "ContinuationCursor": {
      "description": "A bounded opaque continuation cursor.",
      "type": "string",
      "maxLength": 4096,
      "minLength": 1
    },
    "Diversity": {
      "description": "Diversity bias applied when ranking evidence under a tight budget.",
      "oneOf": [
        {
          "description": "Balance across all relevant roles.",
          "type": "string",
          "const": "balanced"
        },
        {
          "description": "Favor implementation evidence.",
          "type": "string",
          "const": "implementation"
        },
        {
          "description": "Favor test evidence.",
          "type": "string",
          "const": "tests"
        },
        {
          "description": "Favor change-impact evidence.",
          "type": "string",
          "const": "impact"
        },
        {
          "description": "Favor architecture evidence.",
          "type": "string",
          "const": "architecture"
        }
      ]
    },
    "GenerationId": {
      "type": "string",
      "pattern": "^gen1_[a-z2-7]{39}$"
    },
    "GenerationSelector": {
      "description": "Generation selector shared by first-slice read tools.",
      "anyOf": [
        {
          "description": "Resolve the currently active immutable generation.",
          "$ref": "#/$defs/ActiveGeneration"
        },
        {
          "description": "Pin an explicit immutable generation.",
          "$ref": "#/$defs/GenerationId"
        }
      ]
    },
    "RepositoryAliasSelector": {
      "description": "Registered repository-alias selector.",
      "type": "object",
      "properties": {
        "alias": {
          "description": "Registered alias, resolved to exactly one repository.",
          "type": "string",
          "maxLength": 256,
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "alias"
      ]
    },
    "RepositoryId": {
      "type": "string",
      "pattern": "^repo1_[a-z2-7]{32}$"
    },
    "RepositoryIdSelector": {
      "description": "Stable repository-ID selector.",
      "type": "object",
      "properties": {
        "repository_id": {
          "description": "Repository identity.",
          "$ref": "#/$defs/RepositoryId"
        }
      },
      "additionalProperties": false,
      "required": [
        "repository_id"
      ]
    },
    "RepositorySelector": {
      "description": "Repository selector accepted by first-slice read tools.",
      "anyOf": [
        {
          "description": "Select by stable repository identifier.",
          "$ref": "#/$defs/RepositoryIdSelector"
        },
        {
          "description": "Select by a configured local alias.",
          "$ref": "#/$defs/RepositoryAliasSelector"
        }
      ]
    },
    "SourcePolicy": {
      "description": "How much source detail the assembled pack may include.",
      "oneOf": [
        {
          "description": "Only stable references, no source text.",
          "type": "string",
          "const": "references_only"
        },
        {
          "description": "Symbol signatures without bodies.",
          "type": "string",
          "const": "signatures"
        },
        {
          "description": "Small focused snippets around the evidence.",
          "type": "string",
          "const": "focused_snippets"
        },
        {
          "description": "Fuller evidence snippets up to the source budget.",
          "type": "string",
          "const": "evidence_heavy"
        }
      ]
    },
    "SymbolId": {
      "type": "string",
      "pattern": "^sym1_[a-z2-7]{39}$"
    }
  }
}
